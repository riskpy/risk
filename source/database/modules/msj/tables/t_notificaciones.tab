create table T_NOTIFICACIONES
(
  id_notificacion         NUMBER generated by default on null as identity (nocache),
  id_usuario              NUMBER,
  suscripcion             VARCHAR2(500) not null,
  titulo                  VARCHAR2(160),
  contenido               VARCHAR2(500),
  estado                  VARCHAR2(1) default 'P' not null,
  fecha_envio             DATE,
  respuesta_envio         VARCHAR2(1000),
  cantidad_intentos_envio NUMBER(3),
  prioridad_envio         NUMBER(3),
  datos_extra             CLOB,
  usuario_insercion       VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion         TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion    VARCHAR2(300),
  fecha_modificacion      TIMESTAMP(2)
)
;
comment on table T_NOTIFICACIONES
  is 'Notificaciones push';
comment on column T_NOTIFICACIONES.id_notificacion
  is 'Identificador de la notificación push';
comment on column T_NOTIFICACIONES.id_usuario
  is 'Usuario destino de la notificación push';
comment on column T_NOTIFICACIONES.suscripcion
  is 'Tag o expresión destino de la notificación push';
comment on column T_NOTIFICACIONES.titulo
  is 'Título de la notificación push';
comment on column T_NOTIFICACIONES.contenido
  is 'Contenido de la notificación push';
comment on column T_NOTIFICACIONES.estado
  is 'Estado de envío';
comment on column T_NOTIFICACIONES.fecha_envio
  is 'Fecha de envío';
comment on column T_NOTIFICACIONES.respuesta_envio
  is 'Respuesta del proceso de envío';
comment on column T_NOTIFICACIONES.cantidad_intentos_envio
  is 'Cantidad de intentos de envío';
comment on column T_NOTIFICACIONES.prioridad_envio
  is 'Prioridad de envío';
comment on column T_NOTIFICACIONES.datos_extra
  is 'Datos extra de la notificación push';
comment on column T_NOTIFICACIONES.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_NOTIFICACIONES.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_NOTIFICACIONES.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_NOTIFICACIONES.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_NOTIFICACIONES
  add constraint PK_NOTIFICACIONES primary key (ID_NOTIFICACION);
alter table T_NOTIFICACIONES
  add constraint CK_NOTIFICACIONES_DATOS_EXTRA
  check (DATOS_EXTRA IS JSON);

