create table T_CORREOS
(
  id_correo               NUMBER generated by default on null as identity,
  id_usuario              NUMBER,
  destinatario            VARCHAR2(2000) not null,
  asunto                  VARCHAR2(2000) not null,
  contenido               CLOB not null,
  remitente               VARCHAR2(1000),
  destino_respuesta       VARCHAR2(1000),
  destinatario_cc         VARCHAR2(2000),
  destinatario_bcc        VARCHAR2(2000),
  estado                  VARCHAR2(1) default 'P' not null,
  id_categoria            NUMBER not null,
  fecha_envio             TIMESTAMP(2),
  cantidad_intentos_envio NUMBER(3),
  id_externo_envio        VARCHAR2(255),
  codigo_respuesta_envio  NUMBER(6),
  respuesta_envio         VARCHAR2(1000),
  usuario_insercion       VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion         TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion    VARCHAR2(300),
  fecha_modificacion      TIMESTAMP(2)
)
;
comment on table T_CORREOS
  is 'Correos electrónicos (E-mail)';
comment on column T_CORREOS.id_correo
  is 'Identificador del correo electrónico';
comment on column T_CORREOS.id_usuario
  is 'Usuario destino del correo electrónico';
comment on column T_CORREOS.destinatario
  is 'Campo ''To'' del mensaje';
comment on column T_CORREOS.asunto
  is 'Campo ''Subject'' del mensaje';
comment on column T_CORREOS.contenido
  is 'Cuerpo del mensaje';
comment on column T_CORREOS.remitente
  is 'Campo ''From'' del mensaje';
comment on column T_CORREOS.destino_respuesta
  is 'Campo ''Reply-To'' del mensaje';
comment on column T_CORREOS.destinatario_cc
  is 'Campo ''CC'' del mensaje';
comment on column T_CORREOS.destinatario_bcc
  is 'Campo ''BCC'' del mensaje';
comment on column T_CORREOS.estado
  is 'Estado de envío';
comment on column T_CORREOS.id_categoria
  is 'Identificador de la categoría del correo electrónico';
comment on column T_CORREOS.fecha_envio
  is 'Fecha de envío';
comment on column T_CORREOS.cantidad_intentos_envio
  is 'Cantidad de intentos de envío';
comment on column T_CORREOS.id_externo_envio
  is 'Identificador externo de envío del correo electrónico';
comment on column T_CORREOS.codigo_respuesta_envio
  is 'Código de respuesta de envío del correo electrónico';
comment on column T_CORREOS.respuesta_envio
  is 'Descripción de respuesta de envío del correo electrónico';
comment on column T_CORREOS.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_CORREOS.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_CORREOS.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_CORREOS.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_CORREOS
  add constraint PK_CORREOS primary key (ID_CORREO);
