create table T_CORREO_ADJUNTOS
(
  id_correo_adjunto    NUMBER generated by default on null as identity (nocache),
  id_correo            NUMBER,
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_CORREO_ADJUNTOS
  is 'Archivos adjuntos de Correos electrónicos (E-mail)';
comment on column T_CORREO_ADJUNTOS.id_correo_adjunto
  is 'Identificador del archivo adjunto';
comment on column T_CORREO_ADJUNTOS.id_correo
  is 'Identificador del correo electrónico';
comment on column T_CORREO_ADJUNTOS.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_CORREO_ADJUNTOS.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_CORREO_ADJUNTOS.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_CORREO_ADJUNTOS.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_CORREO_ADJUNTOS
  add constraint PK_CORREO_ADJUNTOS primary key (ID_CORREO_ADJUNTO);

