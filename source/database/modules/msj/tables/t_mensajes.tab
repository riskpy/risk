create table T_MENSAJES
(
  id_mensaje              NUMBER generated by default on null as identity (nocache),
  id_usuario              NUMBER,
  numero_telefono         VARCHAR2(160) not null,
  contenido               VARCHAR2(160) not null,
  estado                  VARCHAR2(1) default 'P' not null,
  fecha_envio             DATE,
  respuesta_envio         VARCHAR2(1000),
  cantidad_intentos_envio NUMBER(3),
  prioridad_envio         NUMBER(3),
  usuario_insercion       VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion         TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion    VARCHAR2(300),
  fecha_modificacion      TIMESTAMP(2)
)
;
comment on table T_MENSAJES
  is 'Mensajes de texto (SMS)';
comment on column T_MENSAJES.id_mensaje
  is 'Identificador del mensaje de texto';
comment on column T_MENSAJES.id_usuario
  is 'Usuario destino del mensaje de texto';
comment on column T_MENSAJES.numero_telefono
  is 'Número de teléfono destino del mensaje de texto';
comment on column T_MENSAJES.contenido
  is 'Contenido del mensaje';
comment on column T_MENSAJES.estado
  is 'Estado de envío';
comment on column T_MENSAJES.fecha_envio
  is 'Fecha de envío';
comment on column T_MENSAJES.respuesta_envio
  is 'Respuesta del proceso de envío';
comment on column T_MENSAJES.cantidad_intentos_envio
  is 'Cantidad de intentos de envío';
comment on column T_MENSAJES.prioridad_envio
  is 'Prioridad de envío';
comment on column T_MENSAJES.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_MENSAJES.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_MENSAJES.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_MENSAJES.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_MENSAJES
  add constraint PK_MENSAJES primary key (ID_MENSAJE);

