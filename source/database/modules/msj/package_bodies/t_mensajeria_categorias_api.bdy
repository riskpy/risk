    ELSE
      RETURN create_row (
        p_id_categoria  => p_row.ID_CATEGORIA /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_descripcion   => p_row.DESCRIPCION,
