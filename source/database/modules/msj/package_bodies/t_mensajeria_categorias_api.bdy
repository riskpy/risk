  PROCEDURE set_descripcion (
    p_id_categoria IN T_MENSAJERIA_CATEGORIAS.ID_CATEGORIA%TYPE /*PK*/,
    p_descripcion  IN T_MENSAJERIA_CATEGORIAS.DESCRIPCION%TYPE )
  IS
  BEGIN
    UPDATE
      T_MENSAJERIA_CATEGORIAS
    SET
      DESCRIPCION          = p_descripcion,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_CATEGORIA = p_id_categoria;
  END set_descripcion;

  PROCEDURE set_detalle (
