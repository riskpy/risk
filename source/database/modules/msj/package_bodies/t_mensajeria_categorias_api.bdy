  FUNCTION create_or_update_row (
    p_id_categoria  IN T_MENSAJERIA_CATEGORIAS.ID_CATEGORIA%TYPE DEFAULT NULL /*PK*/,
    p_descripcion   IN T_MENSAJERIA_CATEGORIAS.DESCRIPCION%TYPE,
    p_detalle       IN T_MENSAJERIA_CATEGORIAS.DETALLE%TYPE,
    p_estado        IN T_MENSAJERIA_CATEGORIAS.ESTADO%TYPE,
    p_fecha_inicio  IN T_MENSAJERIA_CATEGORIAS.FECHA_INICIO%TYPE,
    p_fecha_fin     IN T_MENSAJERIA_CATEGORIAS.FECHA_FIN%TYPE,
    p_telefonia     IN T_MENSAJERIA_CATEGORIAS.TELEFONIA%TYPE,
    p_clasificacion IN T_MENSAJERIA_CATEGORIAS.CLASIFICACION%TYPE,
    p_prioridad     IN T_MENSAJERIA_CATEGORIAS.PRIORIDAD%TYPE )
  RETURN T_MENSAJERIA_CATEGORIAS.ID_CATEGORIA%TYPE
  IS
  BEGIN
    IF row_exists(
      p_id_categoria => p_id_categoria
    )
    THEN
      RETURN update_row (
        p_id_categoria  => p_id_categoria /*PK*/,
        p_descripcion   => p_descripcion,
        p_detalle       => p_detalle,
        p_estado        => p_estado,
        p_fecha_inicio  => p_fecha_inicio,
        p_fecha_fin     => p_fecha_fin,
        p_telefonia     => p_telefonia,
        p_clasificacion => p_clasificacion,
        p_prioridad     => p_prioridad );
    ELSE
      RETURN create_row (
        p_id_categoria  => p_id_categoria /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_descripcion   => p_descripcion,
        p_detalle       => p_detalle,
        p_estado        => p_estado,
        p_fecha_inicio  => p_fecha_inicio,
        p_fecha_fin     => p_fecha_fin,
        p_telefonia     => p_telefonia,
        p_clasificacion => p_clasificacion,
        p_prioridad     => p_prioridad );
    END IF;
  END create_or_update_row;

