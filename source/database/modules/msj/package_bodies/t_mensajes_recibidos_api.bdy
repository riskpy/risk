        p_id_mensaje              => p_row.ID_MENSAJE /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_numero_telefono_origen  => p_row.NUMERO_TELEFONO_ORIGEN,
        p_numero_telefono_destino => p_row.NUMERO_TELEFONO_DESTINO,
        p_contenido               => p_row.CONTENIDO,
        p_telefonia               => p_row.TELEFONIA,
        p_fecha_recepcion         => p_row.FECHA_RECEPCION,
        p_id_usuario              => p_row.ID_USUARIO );
    END IF;
  END create_or_update_row;

  PROCEDURE create_or_update_row (
    p_row IN T_MENSAJES_RECIBIDOS%ROWTYPE )
  IS
  BEGIN
    IF row_exists(
      p_id_mensaje => p_row.ID_MENSAJE
    )
    THEN
      update_row (
        p_id_mensaje              => p_row.ID_MENSAJE /*PK*/,
        p_numero_telefono_origen  => p_row.NUMERO_TELEFONO_ORIGEN,
        p_numero_telefono_destino => p_row.NUMERO_TELEFONO_DESTINO,
        p_contenido               => p_row.CONTENIDO,
        p_telefonia               => p_row.TELEFONIA,
        p_fecha_recepcion         => p_row.FECHA_RECEPCION,
        p_id_usuario              => p_row.ID_USUARIO );
    ELSE
      create_row (
        p_id_mensaje              => p_row.ID_MENSAJE /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_numero_telefono_origen  => p_row.NUMERO_TELEFONO_ORIGEN,
        p_numero_telefono_destino => p_row.NUMERO_TELEFONO_DESTINO,
        p_contenido               => p_row.CONTENIDO,
        p_telefonia               => p_row.TELEFONIA,
        p_fecha_recepcion         => p_row.FECHA_RECEPCION,
        p_id_usuario              => p_row.ID_USUARIO );
    END IF;
  END create_or_update_row;

