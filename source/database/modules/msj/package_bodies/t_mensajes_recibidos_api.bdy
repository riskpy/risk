  PROCEDURE set_numero_telefono_origen (
    p_id_mensaje             IN T_MENSAJES_RECIBIDOS.ID_MENSAJE%TYPE /*PK*/,
    p_numero_telefono_origen IN T_MENSAJES_RECIBIDOS.NUMERO_TELEFONO_ORIGEN%TYPE )
  IS
  BEGIN
    UPDATE
      T_MENSAJES_RECIBIDOS
    SET
      NUMERO_TELEFONO_ORIGEN = p_numero_telefono_origen,
      USUARIO_MODIFICACION   = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION     = systimestamp
    WHERE
      ID_MENSAJE = p_id_mensaje;
  END set_numero_telefono_origen;

  PROCEDURE set_numero_telefono_destino (
    p_id_mensaje              IN T_MENSAJES_RECIBIDOS.ID_MENSAJE%TYPE /*PK*/,
    p_numero_telefono_destino IN T_MENSAJES_RECIBIDOS.NUMERO_TELEFONO_DESTINO%TYPE )
  IS
