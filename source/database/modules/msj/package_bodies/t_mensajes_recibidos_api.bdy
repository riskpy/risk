  FUNCTION get_default_row
  RETURN T_MENSAJES_RECIBIDOS%ROWTYPE
  IS
    v_row T_MENSAJES_RECIBIDOS%ROWTYPE;
  BEGIN
    v_row.ID_MENSAJE        := NULL /*PK*/;
    v_row.TELEFONIA         := 'TIG' ;
    v_row.FECHA_RECEPCION   := systimestamp ;
    v_row.USUARIO_INSERCION := SUBSTR(USER, 1, 300) ;
    v_row.FECHA_INSERCION   := SYSTIMESTAMP ;
    RETURN v_row;
  END get_default_row;

END T_MENSAJES_RECIBIDOS_API;
