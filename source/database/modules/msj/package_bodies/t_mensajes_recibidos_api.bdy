  RETURN T_MENSAJES_RECIBIDOS.NUMERO_TELEFONO_ORIGEN%TYPE
  IS
  BEGIN
    RETURN read_row (
      p_id_mensaje => p_id_mensaje ).NUMERO_TELEFONO_ORIGEN;
