  PROCEDURE update_rows (
    p_rows_tab IN t_rows_tab )
  IS
  BEGIN
    FORALL i IN INDICES OF p_rows_tab
      UPDATE
        T_CORREOS
      SET
        ID_USUARIO              = p_rows_tab(i).ID_USUARIO,
        DESTINATARIO            = p_rows_tab(i).DESTINATARIO,
        ASUNTO                  = p_rows_tab(i).ASUNTO,
        CONTENIDO               = p_rows_tab(i).CONTENIDO,
        REMITENTE               = p_rows_tab(i).REMITENTE,
        DESTINO_RESPUESTA       = p_rows_tab(i).DESTINO_RESPUESTA,
        DESTINATARIO_CC         = p_rows_tab(i).DESTINATARIO_CC,
        DESTINATARIO_BCC        = p_rows_tab(i).DESTINATARIO_BCC,
        ESTADO                  = p_rows_tab(i).ESTADO,
        ID_CATEGORIA            = p_rows_tab(i).ID_CATEGORIA /*FK*/,
        FECHA_ENVIO             = p_rows_tab(i).FECHA_ENVIO,
        CANTIDAD_INTENTOS_ENVIO = p_rows_tab(i).CANTIDAD_INTENTOS_ENVIO,
        ID_EXTERNO_ENVIO        = p_rows_tab(i).ID_EXTERNO_ENVIO,
        CODIGO_RESPUESTA_ENVIO  = p_rows_tab(i).CODIGO_RESPUESTA_ENVIO,
        RESPUESTA_ENVIO         = p_rows_tab(i).RESPUESTA_ENVIO,
        USUARIO_MODIFICACION    = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
        FECHA_MODIFICACION      = systimestamp
      WHERE
        ID_CORREO = p_rows_tab(i).ID_CORREO;
  END update_rows;

  PROCEDURE delete_row (
    p_id_correo IN T_CORREOS.ID_CORREO%TYPE /*PK*/ )
  IS
  BEGIN
    DELETE FROM T_CORREOS
    WHERE
      ID_CORREO = p_id_correo;
  END delete_row;

  PROCEDURE delete_rows (
    p_rows_tab IN t_rows_tab )
  IS
  BEGIN
    FORALL i IN INDICES OF p_rows_tab
      DELETE FROM T_CORREOS
       WHERE ID_CORREO = p_rows_tab(i).ID_CORREO;
  END delete_rows;

  FUNCTION create_or_update_row (
    p_id_correo               IN T_CORREOS.ID_CORREO%TYPE DEFAULT NULL /*PK*/,
    p_id_usuario              IN T_CORREOS.ID_USUARIO%TYPE,
    p_destinatario            IN T_CORREOS.DESTINATARIO%TYPE,
    p_asunto                  IN T_CORREOS.ASUNTO%TYPE,
    p_contenido               IN T_CORREOS.CONTENIDO%TYPE,
    p_remitente               IN T_CORREOS.REMITENTE%TYPE,
    p_destino_respuesta       IN T_CORREOS.DESTINO_RESPUESTA%TYPE,
    p_destinatario_cc         IN T_CORREOS.DESTINATARIO_CC%TYPE,
    p_destinatario_bcc        IN T_CORREOS.DESTINATARIO_BCC%TYPE,
    p_estado                  IN T_CORREOS.ESTADO%TYPE,
    p_id_categoria            IN T_CORREOS.ID_CATEGORIA%TYPE /*FK*/,
    p_fecha_envio             IN T_CORREOS.FECHA_ENVIO%TYPE,
    p_cantidad_intentos_envio IN T_CORREOS.CANTIDAD_INTENTOS_ENVIO%TYPE,
    p_id_externo_envio        IN T_CORREOS.ID_EXTERNO_ENVIO%TYPE,
    p_codigo_respuesta_envio  IN T_CORREOS.CODIGO_RESPUESTA_ENVIO%TYPE,
    p_respuesta_envio         IN T_CORREOS.RESPUESTA_ENVIO%TYPE )
  RETURN T_CORREOS.ID_CORREO%TYPE
  IS
  BEGIN
    IF row_exists(
      p_id_correo => p_id_correo
    )
    THEN
      RETURN update_row (
        p_id_correo               => p_id_correo /*PK*/,
        p_id_usuario              => p_id_usuario,
        p_destinatario            => p_destinatario,
        p_asunto                  => p_asunto,
        p_contenido               => p_contenido,
        p_remitente               => p_remitente,
        p_destino_respuesta       => p_destino_respuesta,
        p_destinatario_cc         => p_destinatario_cc,
        p_destinatario_bcc        => p_destinatario_bcc,
        p_estado                  => p_estado,
        p_id_categoria            => p_id_categoria /*FK*/,
        p_fecha_envio             => p_fecha_envio,
        p_cantidad_intentos_envio => p_cantidad_intentos_envio,
        p_id_externo_envio        => p_id_externo_envio,
        p_codigo_respuesta_envio  => p_codigo_respuesta_envio,
        p_respuesta_envio         => p_respuesta_envio );
    ELSE
      RETURN create_row (
        p_id_correo               => p_id_correo /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_id_usuario              => p_id_usuario,
        p_destinatario            => p_destinatario,
        p_asunto                  => p_asunto,
        p_contenido               => p_contenido,
        p_remitente               => p_remitente,
        p_destino_respuesta       => p_destino_respuesta,
        p_destinatario_cc         => p_destinatario_cc,
        p_destinatario_bcc        => p_destinatario_bcc,
        p_estado                  => p_estado,
        p_id_categoria            => p_id_categoria /*FK*/,
        p_fecha_envio             => p_fecha_envio,
        p_cantidad_intentos_envio => p_cantidad_intentos_envio,
        p_id_externo_envio        => p_id_externo_envio,
        p_codigo_respuesta_envio  => p_codigo_respuesta_envio,
        p_respuesta_envio         => p_respuesta_envio );
    END IF;
  END create_or_update_row;

