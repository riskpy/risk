    p_destinatario_cc         IN T_CORREOS.DESTINATARIO_CC%TYPE,
    p_destinatario_bcc        IN T_CORREOS.DESTINATARIO_BCC%TYPE,
    p_estado                  IN T_CORREOS.ESTADO%TYPE,
    p_id_categoria            IN T_CORREOS.ID_CATEGORIA%TYPE /*FK*/,
