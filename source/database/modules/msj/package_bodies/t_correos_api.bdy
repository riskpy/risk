  RETURN T_CORREOS.ID_CORREO%TYPE
  IS
    v_return T_CORREOS.ID_CORREO%TYPE; 
  BEGIN
    UPDATE
      T_CORREOS
    SET
      ID_USUARIO              = p_id_usuario,
      DESTINATARIO            = p_destinatario,
      ASUNTO                  = p_asunto,
      CONTENIDO               = p_contenido,
      REMITENTE               = p_remitente,
      DESTINO_RESPUESTA       = p_destino_respuesta,
      DESTINATARIO_CC         = p_destinatario_cc,
      DESTINATARIO_BCC        = p_destinatario_bcc,
