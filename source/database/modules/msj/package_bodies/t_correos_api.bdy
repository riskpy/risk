  PROCEDURE set_fecha_envio (
    p_id_correo   IN T_CORREOS.ID_CORREO%TYPE /*PK*/,
    p_fecha_envio IN T_CORREOS.FECHA_ENVIO%TYPE )
  IS
  BEGIN
    UPDATE
      T_CORREOS
    SET
      FECHA_ENVIO          = p_fecha_envio,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_CORREO = p_id_correo;
  END set_fecha_envio;

  PROCEDURE set_respuesta_envio (
    p_id_correo       IN T_CORREOS.ID_CORREO%TYPE /*PK*/,
    p_respuesta_envio IN T_CORREOS.RESPUESTA_ENVIO%TYPE )
  IS
  BEGIN
    UPDATE
      T_CORREOS
    SET
      RESPUESTA_ENVIO      = p_respuesta_envio,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_CORREO = p_id_correo;
  END set_respuesta_envio;

  PROCEDURE set_cantidad_intentos_envio (
    p_id_correo               IN T_CORREOS.ID_CORREO%TYPE /*PK*/,
    p_cantidad_intentos_envio IN T_CORREOS.CANTIDAD_INTENTOS_ENVIO%TYPE )
  IS
  BEGIN
    UPDATE
      T_CORREOS
    SET
      CANTIDAD_INTENTOS_ENVIO = p_cantidad_intentos_envio,
      USUARIO_MODIFICACION    = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION      = systimestamp
    WHERE
      ID_CORREO = p_id_correo;
  END set_cantidad_intentos_envio;

  PROCEDURE set_prioridad_envio (
    p_id_correo       IN T_CORREOS.ID_CORREO%TYPE /*PK*/,
    p_prioridad_envio IN T_CORREOS.PRIORIDAD_ENVIO%TYPE )
  IS
  BEGIN
    UPDATE
      T_CORREOS
    SET
      PRIORIDAD_ENVIO      = p_prioridad_envio,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_CORREO = p_id_correo;
  END set_prioridad_envio;

  FUNCTION get_default_row
  RETURN T_CORREOS%ROWTYPE
  IS
    v_row T_CORREOS%ROWTYPE;
  BEGIN
    v_row.ID_CORREO         := NULL /*PK*/;
    v_row.ESTADO            := 'P' ;
    v_row.USUARIO_INSERCION := SUBSTR(USER, 1, 300) ;
    v_row.FECHA_INSERCION   := SYSTIMESTAMP ;
    RETURN v_row;
  END get_default_row;

END T_CORREOS_API;
/

