      p_prioridad_envio         => p_row.PRIORIDAD_ENVIO );
  END update_row;

  PROCEDURE update_rows (
    p_rows_tab IN t_rows_tab )
  IS
  BEGIN
    FORALL i IN INDICES OF p_rows_tab
      UPDATE
        T_CORREOS
      SET
        ID_USUARIO              = p_rows_tab(i).ID_USUARIO,
        MENSAJE_TO              = p_rows_tab(i).MENSAJE_TO,
        MENSAJE_SUBJECT         = p_rows_tab(i).MENSAJE_SUBJECT,
        MENSAJE_BODY            = p_rows_tab(i).MENSAJE_BODY,
        MENSAJE_FROM            = p_rows_tab(i).MENSAJE_FROM,
        MENSAJE_REPLY_TO        = p_rows_tab(i).MENSAJE_REPLY_TO,
        MENSAJE_CC              = p_rows_tab(i).MENSAJE_CC,
        MENSAJE_BCC             = p_rows_tab(i).MENSAJE_BCC,
        ESTADO                  = p_rows_tab(i).ESTADO,
        FECHA_ENVIO             = p_rows_tab(i).FECHA_ENVIO,
        RESPUESTA_ENVIO         = p_rows_tab(i).RESPUESTA_ENVIO,
        CANTIDAD_INTENTOS_ENVIO = p_rows_tab(i).CANTIDAD_INTENTOS_ENVIO,
        PRIORIDAD_ENVIO         = p_rows_tab(i).PRIORIDAD_ENVIO,
        USUARIO_MODIFICACION    = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
        FECHA_MODIFICACION      = systimestamp
      WHERE
        ID_CORREO = p_rows_tab(i).ID_CORREO;
  END update_rows;

  PROCEDURE delete_row (
    p_id_correo IN T_CORREOS.ID_CORREO%TYPE /*PK*/ )
  IS
  BEGIN
    DELETE FROM T_CORREOS
    WHERE
      ID_CORREO = p_id_correo;
  END delete_row;

  PROCEDURE delete_rows (
    p_rows_tab IN t_rows_tab )
  IS
  BEGIN
    FORALL i IN INDICES OF p_rows_tab
      DELETE FROM T_CORREOS
       WHERE ID_CORREO = p_rows_tab(i).ID_CORREO;
  END delete_rows;

  FUNCTION create_or_update_row (
    p_id_correo               IN T_CORREOS.ID_CORREO%TYPE DEFAULT NULL /*PK*/,
    p_id_usuario              IN T_CORREOS.ID_USUARIO%TYPE,
    p_mensaje_to              IN T_CORREOS.MENSAJE_TO%TYPE,
    p_mensaje_subject         IN T_CORREOS.MENSAJE_SUBJECT%TYPE,
    p_mensaje_body            IN T_CORREOS.MENSAJE_BODY%TYPE,
    p_mensaje_from            IN T_CORREOS.MENSAJE_FROM%TYPE,
    p_mensaje_reply_to        IN T_CORREOS.MENSAJE_REPLY_TO%TYPE,
    p_mensaje_cc              IN T_CORREOS.MENSAJE_CC%TYPE,
    p_mensaje_bcc             IN T_CORREOS.MENSAJE_BCC%TYPE,
    p_estado                  IN T_CORREOS.ESTADO%TYPE,
    p_fecha_envio             IN T_CORREOS.FECHA_ENVIO%TYPE,
    p_respuesta_envio         IN T_CORREOS.RESPUESTA_ENVIO%TYPE,
    p_cantidad_intentos_envio IN T_CORREOS.CANTIDAD_INTENTOS_ENVIO%TYPE,
    p_prioridad_envio         IN T_CORREOS.PRIORIDAD_ENVIO%TYPE )
  RETURN T_CORREOS.ID_CORREO%TYPE
  IS
  BEGIN
    IF row_exists(
      p_id_correo => p_id_correo
    )
    THEN
      RETURN update_row (
        p_id_correo               => p_id_correo /*PK*/,
        p_id_usuario              => p_id_usuario,
        p_mensaje_to              => p_mensaje_to,
        p_mensaje_subject         => p_mensaje_subject,
        p_mensaje_body            => p_mensaje_body,
        p_mensaje_from            => p_mensaje_from,
        p_mensaje_reply_to        => p_mensaje_reply_to,
        p_mensaje_cc              => p_mensaje_cc,
        p_mensaje_bcc             => p_mensaje_bcc,
        p_estado                  => p_estado,
        p_fecha_envio             => p_fecha_envio,
        p_respuesta_envio         => p_respuesta_envio,
        p_cantidad_intentos_envio => p_cantidad_intentos_envio,
        p_prioridad_envio         => p_prioridad_envio );
    ELSE
      RETURN create_row (
        p_id_correo               => p_id_correo /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_id_usuario              => p_id_usuario,
        p_mensaje_to              => p_mensaje_to,
        p_mensaje_subject         => p_mensaje_subject,
        p_mensaje_body            => p_mensaje_body,
        p_mensaje_from            => p_mensaje_from,
        p_mensaje_reply_to        => p_mensaje_reply_to,
        p_mensaje_cc              => p_mensaje_cc,
        p_mensaje_bcc             => p_mensaje_bcc,
        p_estado                  => p_estado,
        p_fecha_envio             => p_fecha_envio,
        p_respuesta_envio         => p_respuesta_envio,
        p_cantidad_intentos_envio => p_cantidad_intentos_envio,
        p_prioridad_envio         => p_prioridad_envio );
    END IF;
  END create_or_update_row;

