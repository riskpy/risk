    p_leido                   IN T_NOTIFICACIONES.LEIDO%TYPE )
  RETURN T_NOTIFICACIONES.ID_NOTIFICACION%TYPE
  IS
  BEGIN
    IF row_exists(
      p_id_notificacion => p_id_notificacion
    )
    THEN
      RETURN update_row (
        p_id_notificacion         => p_id_notificacion /*PK*/,
        p_id_usuario              => p_id_usuario,
        p_suscripcion             => p_suscripcion,
