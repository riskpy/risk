  FUNCTION get_default_row
  RETURN T_NOTIFICACIONES%ROWTYPE
  IS
    v_row T_NOTIFICACIONES%ROWTYPE;
  BEGIN
    v_row.ID_NOTIFICACION   := NULL /*PK*/;
    v_row.ESTADO            := 'P' ;
    v_row.LEIDO             := 'N' ;
    v_row.USUARIO_INSERCION := SUBSTR(USER, 1, 300) ;
    v_row.FECHA_INSERCION   := SYSTIMESTAMP ;
    RETURN v_row;
  END get_default_row;

END T_NOTIFICACIONES_API;
/

