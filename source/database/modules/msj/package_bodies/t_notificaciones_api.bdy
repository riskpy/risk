        p_codigo_respuesta_envio  => p_codigo_respuesta_envio,
        p_leido                   => p_leido );
    ELSE
      RETURN create_row (
        p_id_notificacion         => p_id_notificacion /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_id_usuario              => p_id_usuario,
        p_suscripcion             => p_suscripcion,
        p_titulo                  => p_titulo,
