    p_id_externo_envio        IN T_NOTIFICACIONES.ID_EXTERNO_ENVIO%TYPE,
    p_codigo_respuesta_envio  IN T_NOTIFICACIONES.CODIGO_RESPUESTA_ENVIO%TYPE,
    p_leido                   IN T_NOTIFICACIONES.LEIDO%TYPE )
  RETURN T_NOTIFICACIONES.ID_NOTIFICACION%TYPE
  IS
    v_return T_NOTIFICACIONES.ID_NOTIFICACION%TYPE; 
  BEGIN
    UPDATE
      T_NOTIFICACIONES
    SET
      ID_USUARIO              = p_id_usuario,
      SUSCRIPCION             = p_suscripcion,
      TITULO                  = p_titulo,
      CONTENIDO               = p_contenido,
      ESTADO                  = p_estado,
      FECHA_ENVIO             = p_fecha_envio,
      RESPUESTA_ENVIO         = p_respuesta_envio,
      CANTIDAD_INTENTOS_ENVIO = p_cantidad_intentos_envio,
      PRIORIDAD_ENVIO         = p_prioridad_envio,
      DATOS_EXTRA             = p_datos_extra,
      ID_PERSONA              = p_id_persona,
      ID_EJECUCION            = p_id_ejecucion,
      ID_PROGRAMACION         = p_id_programacion,
      TOKEN_NOTIFICACION      = p_token_notificacion,
      ID_CATEGORIA            = p_id_categoria /*FK*/,
      PLATAFORMA              = p_plataforma,
      ID_EXTERNO_ENVIO        = p_id_externo_envio,
      CODIGO_RESPUESTA_ENVIO  = p_codigo_respuesta_envio,
      LEIDO                   = p_leido,
      USUARIO_MODIFICACION    = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION      = systimestamp
    WHERE
      ID_NOTIFICACION = p_id_notificacion
    RETURN 
      ID_NOTIFICACION
    INTO
      v_return;
    RETURN v_return;
  END update_row;

