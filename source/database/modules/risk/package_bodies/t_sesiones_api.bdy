  RETURN T_SESIONES.FECHA_INSERCION%TYPE
  IS
  BEGIN
    RETURN read_row (
      p_id_sesion => p_id_sesion ).FECHA_INSERCION;
  END get_fecha_insercion;

  FUNCTION get_usuario_modificacion (
    p_id_sesion IN T_SESIONES.ID_SESION%TYPE /*PK*/ )
  RETURN T_SESIONES.USUARIO_MODIFICACION%TYPE
  IS
  BEGIN
    RETURN read_row (
      p_id_sesion => p_id_sesion ).USUARIO_MODIFICACION;
  END get_usuario_modificacion;

  FUNCTION get_fecha_modificacion (
    p_id_sesion IN T_SESIONES.ID_SESION%TYPE /*PK*/ )
  RETURN T_SESIONES.FECHA_MODIFICACION%TYPE
  IS
  BEGIN
    RETURN read_row (
      p_id_sesion => p_id_sesion ).FECHA_MODIFICACION;
  END get_fecha_modificacion;

  PROCEDURE set_id_usuario (
    p_id_sesion  IN T_SESIONES.ID_SESION%TYPE /*PK*/,
    p_id_usuario IN T_SESIONES.ID_USUARIO%TYPE )
  IS
  BEGIN
    UPDATE
      T_SESIONES
    SET
      ID_USUARIO           = p_id_usuario /*FK*/,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_SESION = p_id_sesion;
  END set_id_usuario;

