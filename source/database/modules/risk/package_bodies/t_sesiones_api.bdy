    p_id_dispositivo                 IN T_SESIONES.ID_DISPOSITIVO%TYPE /*FK*/,
    p_origen                         IN T_SESIONES.ORIGEN%TYPE,
    p_dato_externo                   IN T_SESIONES.DATO_EXTERNO%TYPE )
  IS
  BEGIN
    UPDATE
      T_SESIONES
    SET
      ID_USUARIO                     = p_id_usuario /*FK*/,
      ID_APLICACION                  = p_id_aplicacion /*FK*/,
      ESTADO                         = p_estado,
      FECHA_ESTADO                   = p_fecha_estado,
      FECHA_AUTENTICACION            = p_fecha_autenticacion,
      ACCESS_TOKEN                   = p_access_token /*UK*/,
      FECHA_EXPIRACION_ACCESS_TOKEN  = p_fecha_expiracion_access_token,
      REFRESH_TOKEN                  = p_refresh_token,
      FECHA_EXPIRACION_REFRESH_TOKEN = p_fecha_expiracion_refresh_token,
      DIRECCION_IP                   = p_direccion_ip,
      HOST                           = p_host,
      TERMINAL                       = p_terminal,
      ID_DISPOSITIVO                 = p_id_dispositivo /*FK*/,
      ORIGEN                         = p_origen,
      DATO_EXTERNO                   = p_dato_externo,
      USUARIO_MODIFICACION           = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION             = systimestamp
    WHERE
      ID_SESION = p_id_sesion;
  END update_row;

