  PROCEDURE update_rows (
    p_rows_tab IN t_rows_tab )
  IS
  BEGIN
    FORALL i IN INDICES OF p_rows_tab
      UPDATE
        T_SESIONES
      SET
        ID_USUARIO                     = p_rows_tab(i).ID_USUARIO /*FK*/,
        ID_APLICACION                  = p_rows_tab(i).ID_APLICACION /*FK*/,
        ESTADO                         = p_rows_tab(i).ESTADO,
        FECHA_ESTADO                   = p_rows_tab(i).FECHA_ESTADO,
        FECHA_AUTENTICACION            = p_rows_tab(i).FECHA_AUTENTICACION,
        ACCESS_TOKEN                   = p_rows_tab(i).ACCESS_TOKEN /*UK*/,
        FECHA_EXPIRACION_ACCESS_TOKEN  = p_rows_tab(i).FECHA_EXPIRACION_ACCESS_TOKEN,
        REFRESH_TOKEN                  = p_rows_tab(i).REFRESH_TOKEN,
        FECHA_EXPIRACION_REFRESH_TOKEN = p_rows_tab(i).FECHA_EXPIRACION_REFRESH_TOKEN,
        DIRECCION_IP                   = p_rows_tab(i).DIRECCION_IP,
        HOST                           = p_rows_tab(i).HOST,
        TERMINAL                       = p_rows_tab(i).TERMINAL,
        ID_DISPOSITIVO                 = p_rows_tab(i).ID_DISPOSITIVO /*FK*/,
        ORIGEN                         = p_rows_tab(i).ORIGEN,
        DATO_EXTERNO                   = p_rows_tab(i).DATO_EXTERNO,
        USUARIO_MODIFICACION           = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
        FECHA_MODIFICACION             = systimestamp
      WHERE
        ID_SESION = p_rows_tab(i).ID_SESION;
  END update_rows;

  PROCEDURE delete_row (
    p_id_sesion IN T_SESIONES.ID_SESION%TYPE /*PK*/ )
  IS
  BEGIN
    DELETE FROM T_SESIONES
    WHERE
      ID_SESION = p_id_sesion;
  END delete_row;

  PROCEDURE delete_rows (
    p_rows_tab IN t_rows_tab )
  IS
  BEGIN
    FORALL i IN INDICES OF p_rows_tab
      DELETE FROM T_SESIONES
       WHERE ID_SESION = p_rows_tab(i).ID_SESION;
  END delete_rows;

  FUNCTION create_or_update_row (
    p_id_sesion                      IN T_SESIONES.ID_SESION%TYPE DEFAULT NULL /*PK*/,
    p_id_usuario                     IN T_SESIONES.ID_USUARIO%TYPE /*FK*/,
    p_id_aplicacion                  IN T_SESIONES.ID_APLICACION%TYPE /*FK*/,
    p_estado                         IN T_SESIONES.ESTADO%TYPE,
    p_fecha_estado                   IN T_SESIONES.FECHA_ESTADO%TYPE,
    p_fecha_autenticacion            IN T_SESIONES.FECHA_AUTENTICACION%TYPE,
    p_access_token                   IN T_SESIONES.ACCESS_TOKEN%TYPE /*UK*/,
    p_fecha_expiracion_access_token  IN T_SESIONES.FECHA_EXPIRACION_ACCESS_TOKEN%TYPE,
    p_refresh_token                  IN T_SESIONES.REFRESH_TOKEN%TYPE,
    p_fecha_expiracion_refresh_token IN T_SESIONES.FECHA_EXPIRACION_REFRESH_TOKEN%TYPE,
    p_direccion_ip                   IN T_SESIONES.DIRECCION_IP%TYPE,
    p_host                           IN T_SESIONES.HOST%TYPE,
    p_terminal                       IN T_SESIONES.TERMINAL%TYPE,
    p_id_dispositivo                 IN T_SESIONES.ID_DISPOSITIVO%TYPE /*FK*/,
    p_origen                         IN T_SESIONES.ORIGEN%TYPE,
    p_dato_externo                   IN T_SESIONES.DATO_EXTERNO%TYPE )
  RETURN T_SESIONES.ID_SESION%TYPE
  IS
  BEGIN
    IF row_exists(
      p_id_sesion => p_id_sesion
    )
    THEN
      RETURN update_row (
        p_id_sesion                      => p_id_sesion /*PK*/,
        p_id_usuario                     => p_id_usuario /*FK*/,
        p_id_aplicacion                  => p_id_aplicacion /*FK*/,
        p_estado                         => p_estado,
        p_fecha_estado                   => p_fecha_estado,
        p_fecha_autenticacion            => p_fecha_autenticacion,
        p_access_token                   => p_access_token /*UK*/,
        p_fecha_expiracion_access_token  => p_fecha_expiracion_access_token,
        p_refresh_token                  => p_refresh_token,
        p_fecha_expiracion_refresh_token => p_fecha_expiracion_refresh_token,
        p_direccion_ip                   => p_direccion_ip,
        p_host                           => p_host,
        p_terminal                       => p_terminal,
        p_id_dispositivo                 => p_id_dispositivo /*FK*/,
        p_origen                         => p_origen,
        p_dato_externo                   => p_dato_externo );
    ELSE
      RETURN create_row (
        p_id_sesion                      => p_id_sesion /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_id_usuario                     => p_id_usuario /*FK*/,
        p_id_aplicacion                  => p_id_aplicacion /*FK*/,
        p_estado                         => p_estado,
        p_fecha_estado                   => p_fecha_estado,
        p_fecha_autenticacion            => p_fecha_autenticacion,
        p_access_token                   => p_access_token /*UK*/,
        p_fecha_expiracion_access_token  => p_fecha_expiracion_access_token,
        p_refresh_token                  => p_refresh_token,
        p_fecha_expiracion_refresh_token => p_fecha_expiracion_refresh_token,
        p_direccion_ip                   => p_direccion_ip,
        p_host                           => p_host,
        p_terminal                       => p_terminal,
        p_id_dispositivo                 => p_id_dispositivo /*FK*/,
        p_origen                         => p_origen,
        p_dato_externo                   => p_dato_externo );
    END IF;
  END create_or_update_row;

