  FUNCTION get_default_row
  RETURN T_SESIONES%ROWTYPE
  IS
    v_row T_SESIONES%ROWTYPE;
  BEGIN
    v_row.ID_SESION         := NULL /*PK*/;
    v_row.USUARIO_INSERCION := SUBSTR(USER, 1, 300) ;
    v_row.FECHA_INSERCION   := SYSTIMESTAMP ;
    RETURN v_row;
  END get_default_row;

END T_SESIONES_API;
