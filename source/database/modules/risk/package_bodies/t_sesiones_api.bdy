    p_fecha_expiracion_access_token     OUT NOCOPY T_SESIONES.FECHA_EXPIRACION_ACCESS_TOKEN%TYPE,
    p_refresh_token                     OUT NOCOPY T_SESIONES.REFRESH_TOKEN%TYPE,
    p_fecha_expiracion_refresh_token    OUT NOCOPY T_SESIONES.FECHA_EXPIRACION_REFRESH_TOKEN%TYPE,
    p_direccion_ip                      OUT NOCOPY T_SESIONES.DIRECCION_IP%TYPE,
    p_host                              OUT NOCOPY T_SESIONES.HOST%TYPE,
    p_terminal                          OUT NOCOPY T_SESIONES.TERMINAL%TYPE,
    p_id_dispositivo                    OUT NOCOPY T_SESIONES.ID_DISPOSITIVO%TYPE /*FK*/,
    p_origen                            OUT NOCOPY T_SESIONES.ORIGEN%TYPE,
    p_dato_externo                      OUT NOCOPY T_SESIONES.DATO_EXTERNO%TYPE,
    p_usuario_insercion                 OUT NOCOPY T_SESIONES.USUARIO_INSERCION%TYPE,
    p_fecha_insercion                   OUT NOCOPY T_SESIONES.FECHA_INSERCION%TYPE,
    p_usuario_modificacion              OUT NOCOPY T_SESIONES.USUARIO_MODIFICACION%TYPE,
    p_fecha_modificacion                OUT NOCOPY T_SESIONES.FECHA_MODIFICACION%TYPE )
  IS
    v_row T_SESIONES%ROWTYPE;
  BEGIN
    v_row := read_row (
      p_id_sesion => p_id_sesion );
    p_id_usuario                     := v_row.ID_USUARIO; 
    p_id_aplicacion                  := v_row.ID_APLICACION; 
    p_estado                         := v_row.ESTADO; 
    p_fecha_estado                   := v_row.FECHA_ESTADO; 
    p_fecha_autenticacion            := v_row.FECHA_AUTENTICACION; 
    p_access_token                   := v_row.ACCESS_TOKEN; 
    p_fecha_expiracion_access_token  := v_row.FECHA_EXPIRACION_ACCESS_TOKEN; 
    p_refresh_token                  := v_row.REFRESH_TOKEN; 
    p_fecha_expiracion_refresh_token := v_row.FECHA_EXPIRACION_REFRESH_TOKEN; 
    p_direccion_ip                   := v_row.DIRECCION_IP; 
    p_host                           := v_row.HOST; 
    p_terminal                       := v_row.TERMINAL; 
    p_id_dispositivo                 := v_row.ID_DISPOSITIVO; 
    p_origen                         := v_row.ORIGEN; 
    p_dato_externo                   := v_row.DATO_EXTERNO; 
    p_usuario_insercion              := v_row.USUARIO_INSERCION; 
    p_fecha_insercion                := v_row.FECHA_INSERCION; 
    p_usuario_modificacion           := v_row.USUARIO_MODIFICACION; 
    p_fecha_modificacion             := v_row.FECHA_MODIFICACION; 
  END read_row;

  FUNCTION read_rows (
    p_ref_cursor IN t_strong_ref_cursor )
  RETURN t_rows_tab
  IS
    v_return t_rows_tab;
  BEGIN
    IF (p_ref_cursor%ISOPEN) THEN
      g_bulk_completed := FALSE;
      FETCH p_ref_cursor BULK COLLECT INTO v_return LIMIT g_bulk_limit;
      IF (v_return.COUNT < g_bulk_limit) THEN
        g_bulk_completed := TRUE;
      END IF;
    END IF;
    RETURN v_return;
  END read_rows;

  FUNCTION update_row (
    p_id_sesion                      IN T_SESIONES.ID_SESION%TYPE DEFAULT NULL /*PK*/,
    p_id_usuario                     IN T_SESIONES.ID_USUARIO%TYPE /*FK*/,
    p_id_aplicacion                  IN T_SESIONES.ID_APLICACION%TYPE /*FK*/,
    p_estado                         IN T_SESIONES.ESTADO%TYPE,
    p_fecha_estado                   IN T_SESIONES.FECHA_ESTADO%TYPE,
    p_fecha_autenticacion            IN T_SESIONES.FECHA_AUTENTICACION%TYPE,
    p_access_token                   IN T_SESIONES.ACCESS_TOKEN%TYPE /*UK*/,
    p_fecha_expiracion_access_token  IN T_SESIONES.FECHA_EXPIRACION_ACCESS_TOKEN%TYPE,
    p_refresh_token                  IN T_SESIONES.REFRESH_TOKEN%TYPE,
    p_fecha_expiracion_refresh_token IN T_SESIONES.FECHA_EXPIRACION_REFRESH_TOKEN%TYPE,
    p_direccion_ip                   IN T_SESIONES.DIRECCION_IP%TYPE,
    p_host                           IN T_SESIONES.HOST%TYPE,
    p_terminal                       IN T_SESIONES.TERMINAL%TYPE,
    p_id_dispositivo                 IN T_SESIONES.ID_DISPOSITIVO%TYPE /*FK*/,
    p_origen                         IN T_SESIONES.ORIGEN%TYPE,
    p_dato_externo                   IN T_SESIONES.DATO_EXTERNO%TYPE )
  RETURN T_SESIONES.ID_SESION%TYPE
  IS
    v_return T_SESIONES.ID_SESION%TYPE; 
  BEGIN
    UPDATE
      T_SESIONES
    SET
      ID_USUARIO                     = p_id_usuario /*FK*/,
      ID_APLICACION                  = p_id_aplicacion /*FK*/,
      ESTADO                         = p_estado,
      FECHA_ESTADO                   = p_fecha_estado,
      FECHA_AUTENTICACION            = p_fecha_autenticacion,
      ACCESS_TOKEN                   = p_access_token /*UK*/,
      FECHA_EXPIRACION_ACCESS_TOKEN  = p_fecha_expiracion_access_token,
      REFRESH_TOKEN                  = p_refresh_token,
      FECHA_EXPIRACION_REFRESH_TOKEN = p_fecha_expiracion_refresh_token,
      DIRECCION_IP                   = p_direccion_ip,
      HOST                           = p_host,
      TERMINAL                       = p_terminal,
      ID_DISPOSITIVO                 = p_id_dispositivo /*FK*/,
      ORIGEN                         = p_origen,
      DATO_EXTERNO                   = p_dato_externo,
      USUARIO_MODIFICACION           = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION             = systimestamp
    WHERE
      ID_SESION = p_id_sesion
    RETURN 
      ID_SESION
    INTO
      v_return;
    RETURN v_return;
  END update_row;

