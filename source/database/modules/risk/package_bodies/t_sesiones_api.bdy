  FUNCTION read_row (
    p_id_sesion IN T_SESIONES.ID_SESION%TYPE /*PK*/ )
  RETURN T_SESIONES%ROWTYPE
  IS
    v_row T_SESIONES%ROWTYPE;
    CURSOR cur_row IS
      SELECT * FROM T_SESIONES
      WHERE
        ID_SESION = p_id_sesion;
  BEGIN
    OPEN cur_row;
    FETCH cur_row INTO v_row;
    CLOSE cur_row;
    RETURN v_row;
  END read_row;

  FUNCTION read_row (
    p_access_token IN T_SESIONES.ACCESS_TOKEN%TYPE /*UK*/ )
  RETURN T_SESIONES%ROWTYPE
  IS
    v_row T_SESIONES%ROWTYPE;
    CURSOR cur_row IS
      SELECT *
        FROM T_SESIONES
       WHERE COALESCE(ACCESS_TOKEN, '@@@@@@@@@@@@@@@') = COALESCE(p_access_token, '@@@@@@@@@@@@@@@');
  BEGIN
    OPEN cur_row;
    FETCH cur_row INTO v_row;
    CLOSE cur_row;
    RETURN v_row;
  END;

  PROCEDURE read_row (
    p_id_sesion                      IN            T_SESIONES.ID_SESION%TYPE /*PK*/,
    p_id_usuario                        OUT NOCOPY T_SESIONES.ID_USUARIO%TYPE /*FK*/,
    p_id_aplicacion                     OUT NOCOPY T_SESIONES.ID_APLICACION%TYPE /*FK*/,
    p_estado                            OUT NOCOPY T_SESIONES.ESTADO%TYPE,
    p_fecha_estado                      OUT NOCOPY T_SESIONES.FECHA_ESTADO%TYPE,
    p_fecha_autenticacion               OUT NOCOPY T_SESIONES.FECHA_AUTENTICACION%TYPE,
