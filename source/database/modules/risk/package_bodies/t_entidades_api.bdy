    IF row_exists(
      p_id_entidad => p_id_entidad
    )
    THEN
      RETURN update_row (
        p_id_entidad       => p_id_entidad /*PK*/,
        p_alias            => p_alias /*UK*/,
        p_id_persona       => p_id_persona /*FK*/,
        p_estado           => p_estado,
        p_direccion_correo => p_direccion_correo,
        p_numero_telefono  => p_numero_telefono,
        p_origen           => p_origen /*UK*/ /*FK*/,
        p_id_externo       => p_id_externo /*UK*/ );
    ELSE
      RETURN create_row (
        p_id_entidad       => p_id_entidad /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_alias            => p_alias /*UK*/,
        p_id_persona       => p_id_persona /*FK*/,
        p_estado           => p_estado,
