        p_numero_telefono  => p_numero_telefono,
        p_origen           => p_origen /*UK*/ /*FK*/,
        p_id_externo       => p_id_externo /*UK*/ );
    END IF;
  END create_or_update_row;

  FUNCTION create_or_update_row (
    p_row IN T_ENTIDADES%ROWTYPE )
  RETURN T_ENTIDADES.ID_ENTIDAD%TYPE
  IS
  BEGIN
    IF row_exists(
      p_id_entidad => p_row.ID_ENTIDAD
    )
    THEN
      RETURN update_row (
        p_id_entidad       => p_row.ID_ENTIDAD /*PK*/,
        p_alias            => p_row.ALIAS /*UK*/,
        p_id_persona       => p_row.ID_PERSONA /*FK*/,
        p_estado           => p_row.ESTADO,
        p_direccion_correo => p_row.DIRECCION_CORREO,
        p_numero_telefono  => p_row.NUMERO_TELEFONO,
        p_origen           => p_row.ORIGEN /*UK*/ /*FK*/,
        p_id_externo       => p_row.ID_EXTERNO /*UK*/ );
    ELSE
      RETURN create_row (
        p_id_entidad       => p_row.ID_ENTIDAD /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_alias            => p_row.ALIAS /*UK*/,
        p_id_persona       => p_row.ID_PERSONA /*FK*/,
        p_estado           => p_row.ESTADO,
        p_direccion_correo => p_row.DIRECCION_CORREO,
        p_numero_telefono  => p_row.NUMERO_TELEFONO,
        p_origen           => p_row.ORIGEN /*UK*/ /*FK*/,
        p_id_externo       => p_row.ID_EXTERNO /*UK*/ );
    END IF;
  END create_or_update_row;

