  PROCEDURE set_alias (
    p_id_entidad IN T_ENTIDADES.ID_ENTIDAD%TYPE /*PK*/,
    p_alias      IN T_ENTIDADES.ALIAS%TYPE )
  IS
  BEGIN
    UPDATE
      T_ENTIDADES
    SET
      ALIAS                = p_alias /*UK*/,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_ENTIDAD = p_id_entidad;
  END set_alias;

  PROCEDURE set_id_persona (
    p_id_entidad IN T_ENTIDADES.ID_ENTIDAD%TYPE /*PK*/,
    p_id_persona IN T_ENTIDADES.ID_PERSONA%TYPE )
