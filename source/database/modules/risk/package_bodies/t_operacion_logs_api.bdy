    p_id_usuario       IN T_OPERACION_LOGS.ID_USUARIO%TYPE )
  IS
  BEGIN
    UPDATE
      T_OPERACION_LOGS
    SET
      ID_USUARIO           = p_id_usuario,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_OPERACION_LOG = p_id_operacion_log;
  END set_id_usuario;

  PROCEDURE set_id_entidad (
    p_id_operacion_log IN T_OPERACION_LOGS.ID_OPERACION_LOG%TYPE /*PK*/,
    p_id_entidad       IN T_OPERACION_LOGS.ID_ENTIDAD%TYPE )
  IS
  BEGIN
    UPDATE
      T_OPERACION_LOGS
    SET
      ID_ENTIDAD           = p_id_entidad,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_OPERACION_LOG = p_id_operacion_log;
  END set_id_entidad;

  PROCEDURE set_id_sesion (
    p_id_operacion_log IN T_OPERACION_LOGS.ID_OPERACION_LOG%TYPE /*PK*/,
    p_id_sesion        IN T_OPERACION_LOGS.ID_SESION%TYPE )
  IS
  BEGIN
    UPDATE
      T_OPERACION_LOGS
    SET
      ID_SESION            = p_id_sesion,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_OPERACION_LOG = p_id_operacion_log;
  END set_id_sesion;

  PROCEDURE set_id_dispositivo (
    p_id_operacion_log IN T_OPERACION_LOGS.ID_OPERACION_LOG%TYPE /*PK*/,
    p_id_dispositivo   IN T_OPERACION_LOGS.ID_DISPOSITIVO%TYPE )
  IS
  BEGIN
    UPDATE
      T_OPERACION_LOGS
    SET
      ID_DISPOSITIVO       = p_id_dispositivo,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_OPERACION_LOG = p_id_operacion_log;
  END set_id_dispositivo;

END T_OPERACION_LOGS_API;
