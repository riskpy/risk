  PROCEDURE set_id_operacion (
    p_id_operacion_log IN T_OPERACION_LOGS.ID_OPERACION_LOG%TYPE /*PK*/,
    p_id_operacion     IN T_OPERACION_LOGS.ID_OPERACION%TYPE )
  IS
  BEGIN
    UPDATE
      T_OPERACION_LOGS
    SET
      ID_OPERACION         = p_id_operacion,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_OPERACION_LOG = p_id_operacion_log;
  END set_id_operacion;

