        CONTEXTO             = p_rows_tab(i).CONTEXTO,
        VERSION              = p_rows_tab(i).VERSION,
        PARAMETROS           = p_rows_tab(i).PARAMETROS,
        RESPUESTA            = p_rows_tab(i).RESPUESTA,
        FECHA_HORA_INICIO    = p_rows_tab(i).FECHA_HORA_INICIO,
        FECHA_HORA_FIN       = p_rows_tab(i).FECHA_HORA_FIN,
        DURACION             = p_rows_tab(i).DURACION,
        SQL_EJECUCION        = p_rows_tab(i).SQL_EJECUCION,
        ID_USUARIO           = p_rows_tab(i).ID_USUARIO,
        ID_ENTIDAD           = p_rows_tab(i).ID_ENTIDAD,
        ID_SESION            = p_rows_tab(i).ID_SESION,
        ID_DISPOSITIVO       = p_rows_tab(i).ID_DISPOSITIVO,
        USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
        FECHA_MODIFICACION   = systimestamp
      WHERE
        ID_OPERACION_LOG = p_rows_tab(i).ID_OPERACION_LOG;
  END update_rows;

  PROCEDURE delete_row (
    p_id_operacion_log IN T_OPERACION_LOGS.ID_OPERACION_LOG%TYPE /*PK*/ )
  IS
  BEGIN
    DELETE FROM T_OPERACION_LOGS
    WHERE
      ID_OPERACION_LOG = p_id_operacion_log;
  END delete_row;

  PROCEDURE delete_rows (
    p_rows_tab IN t_rows_tab )
  IS
  BEGIN
    FORALL i IN INDICES OF p_rows_tab
      DELETE FROM T_OPERACION_LOGS
       WHERE ID_OPERACION_LOG = p_rows_tab(i).ID_OPERACION_LOG;
  END delete_rows;

