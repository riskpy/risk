        p_id_rol           => p_row.ID_ROL /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_nombre           => p_row.NOMBRE /*UK*/,
        p_activo           => p_row.ACTIVO,
        p_detalle          => p_row.DETALLE,
        p_origen           => p_row.ORIGEN /*FK*/,
        p_id_externo       => p_row.ID_EXTERNO,
        p_implicito        => p_row.IMPLICITO,
        p_direccion_correo => p_row.DIRECCION_CORREO,
        p_numero_telefono  => p_row.NUMERO_TELEFONO );
    END IF;
  END create_or_update_row;

  PROCEDURE create_or_update_row (
    p_row IN T_ROLES%ROWTYPE )
  IS
  BEGIN
    IF row_exists(
      p_id_rol => p_row.ID_ROL
    )
    THEN
      update_row (
        p_id_rol           => p_row.ID_ROL /*PK*/,
        p_nombre           => p_row.NOMBRE /*UK*/,
        p_activo           => p_row.ACTIVO,
        p_detalle          => p_row.DETALLE,
        p_origen           => p_row.ORIGEN /*FK*/,
        p_id_externo       => p_row.ID_EXTERNO,
        p_implicito        => p_row.IMPLICITO,
        p_direccion_correo => p_row.DIRECCION_CORREO,
        p_numero_telefono  => p_row.NUMERO_TELEFONO );
    ELSE
      create_row (
        p_id_rol           => p_row.ID_ROL /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_nombre           => p_row.NOMBRE /*UK*/,
        p_activo           => p_row.ACTIVO,
        p_detalle          => p_row.DETALLE,
        p_origen           => p_row.ORIGEN /*FK*/,
        p_id_externo       => p_row.ID_EXTERNO,
        p_implicito        => p_row.IMPLICITO,
        p_direccion_correo => p_row.DIRECCION_CORREO,
        p_numero_telefono  => p_row.NUMERO_TELEFONO );
    END IF;
  END create_or_update_row;

