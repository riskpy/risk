    p_direccion_correo IN T_ROLES.DIRECCION_CORREO%TYPE,
    p_numero_telefono  IN T_ROLES.NUMERO_TELEFONO%TYPE )
  RETURN T_ROLES.ID_ROL%TYPE
  IS
  BEGIN
    IF row_exists(
      p_id_rol => p_id_rol
    )
    THEN
      RETURN update_row (
        p_id_rol           => p_id_rol /*PK*/,
        p_nombre           => p_nombre /*UK*/,
        p_activo           => p_activo,
        p_detalle          => p_detalle,
        p_origen           => p_origen /*FK*/,
        p_id_externo       => p_id_externo,
        p_implicito        => p_implicito,
        p_direccion_correo => p_direccion_correo,
        p_numero_telefono  => p_numero_telefono );
    ELSE
      RETURN create_row (
        p_id_rol           => p_id_rol /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_nombre           => p_nombre /*UK*/,
        p_activo           => p_activo,
        p_detalle          => p_detalle,
