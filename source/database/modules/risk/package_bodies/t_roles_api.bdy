  FUNCTION create_or_update_row (
    p_id_rol           IN T_ROLES.ID_ROL%TYPE DEFAULT NULL /*PK*/,
    p_nombre           IN T_ROLES.NOMBRE%TYPE /*UK*/,
    p_activo           IN T_ROLES.ACTIVO%TYPE,
