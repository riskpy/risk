  PROCEDURE set_nombre (
    p_id_rol IN T_ROLES.ID_ROL%TYPE /*PK*/,
    p_nombre IN T_ROLES.NOMBRE%TYPE )
  IS
  BEGIN
    UPDATE
      T_ROLES
    SET
      NOMBRE               = p_nombre /*UK*/,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_ROL = p_id_rol;
  END set_nombre;

  PROCEDURE set_activo (
