        p_duracion               => p_duracion,
        p_datos                  => p_datos );
    END IF;
  END create_or_update_row;

  FUNCTION create_or_update_row (
    p_row IN T_MONITOREO_EJECUCIONES%ROWTYPE )
  RETURN T_MONITOREO_EJECUCIONES%ROWTYPE
  IS
  BEGIN
    IF row_exists(
      p_id_monitoreo_ejecucion => p_row.ID_MONITOREO_EJECUCION,
      p_id_monitoreo           => p_row.ID_MONITOREO
    )
    THEN
      RETURN update_row (
        p_id_monitoreo_ejecucion => p_row.ID_MONITOREO_EJECUCION /*PK*/,
        p_id_monitoreo           => p_row.ID_MONITOREO /*PK*/ /*FK*/,
        p_fecha_inicio_ejecucion => p_row.FECHA_INICIO_EJECUCION,
        p_fecha_fin_ejecucion    => p_row.FECHA_FIN_EJECUCION,
        p_duracion               => p_row.DURACION,
        p_datos                  => p_row.DATOS );
    ELSE
      RETURN create_row (
        p_id_monitoreo_ejecucion => p_row.ID_MONITOREO_EJECUCION /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_id_monitoreo           => p_row.ID_MONITOREO /*PK*/ /*FK*/,
        p_fecha_inicio_ejecucion => p_row.FECHA_INICIO_EJECUCION,
        p_fecha_fin_ejecucion    => p_row.FECHA_FIN_EJECUCION,
        p_duracion               => p_row.DURACION,
        p_datos                  => p_row.DATOS );
    END IF;
  END create_or_update_row;

