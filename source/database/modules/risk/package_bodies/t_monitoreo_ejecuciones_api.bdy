  PROCEDURE set_fecha_inicio_ejecucion (
    p_id_monitoreo_ejecucion IN T_MONITOREO_EJECUCIONES.ID_MONITOREO_EJECUCION%TYPE /*PK*/,
    p_id_monitoreo           IN T_MONITOREO_EJECUCIONES.ID_MONITOREO%TYPE /*PK*/,
    p_fecha_inicio_ejecucion IN T_MONITOREO_EJECUCIONES.FECHA_INICIO_EJECUCION%TYPE )
  IS
  BEGIN
    UPDATE
      T_MONITOREO_EJECUCIONES
    SET
      FECHA_INICIO_EJECUCION = p_fecha_inicio_ejecucion,
      USUARIO_MODIFICACION   = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION     = systimestamp
    WHERE
      ID_MONITOREO_EJECUCION = p_id_monitoreo_ejecucion
      AND ID_MONITOREO = p_id_monitoreo;
  END set_fecha_inicio_ejecucion;

  PROCEDURE set_fecha_fin_ejecucion (
    p_id_monitoreo_ejecucion IN T_MONITOREO_EJECUCIONES.ID_MONITOREO_EJECUCION%TYPE /*PK*/,
    p_id_monitoreo           IN T_MONITOREO_EJECUCIONES.ID_MONITOREO%TYPE /*PK*/,
    p_fecha_fin_ejecucion    IN T_MONITOREO_EJECUCIONES.FECHA_FIN_EJECUCION%TYPE )
  IS
  BEGIN
    UPDATE
      T_MONITOREO_EJECUCIONES
    SET
      FECHA_FIN_EJECUCION  = p_fecha_fin_ejecucion,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_MONITOREO_EJECUCION = p_id_monitoreo_ejecucion
      AND ID_MONITOREO = p_id_monitoreo;
  END set_fecha_fin_ejecucion;

  PROCEDURE set_duracion (
    p_id_monitoreo_ejecucion IN T_MONITOREO_EJECUCIONES.ID_MONITOREO_EJECUCION%TYPE /*PK*/,
    p_id_monitoreo           IN T_MONITOREO_EJECUCIONES.ID_MONITOREO%TYPE /*PK*/,
    p_duracion               IN T_MONITOREO_EJECUCIONES.DURACION%TYPE )
  IS
  BEGIN
    UPDATE
      T_MONITOREO_EJECUCIONES
    SET
      DURACION             = p_duracion,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_MONITOREO_EJECUCION = p_id_monitoreo_ejecucion
      AND ID_MONITOREO = p_id_monitoreo;
  END set_duracion;

  PROCEDURE set_datos (
    p_id_monitoreo_ejecucion IN T_MONITOREO_EJECUCIONES.ID_MONITOREO_EJECUCION%TYPE /*PK*/,
    p_id_monitoreo           IN T_MONITOREO_EJECUCIONES.ID_MONITOREO%TYPE /*PK*/,
    p_datos                  IN T_MONITOREO_EJECUCIONES.DATOS%TYPE )
  IS
  BEGIN
    UPDATE
      T_MONITOREO_EJECUCIONES
    SET
      DATOS                = p_datos,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_MONITOREO_EJECUCION = p_id_monitoreo_ejecucion
      AND ID_MONITOREO = p_id_monitoreo;
  END set_datos;

END T_MONITOREO_EJECUCIONES_API;
