  PROCEDURE update_rows (
    p_rows_tab IN t_rows_tab )
  IS
  BEGIN
    FORALL i IN INDICES OF p_rows_tab
      UPDATE
        T_DISPOSITIVOS
      SET
        TOKEN_DISPOSITIVO         = p_rows_tab(i).TOKEN_DISPOSITIVO /*UK*/,
        FECHA_ULTIMO_ACCESO       = p_rows_tab(i).FECHA_ULTIMO_ACCESO,
        ID_APLICACION             = p_rows_tab(i).ID_APLICACION /*FK*/,
        NOMBRE_SISTEMA_OPERATIVO  = p_rows_tab(i).NOMBRE_SISTEMA_OPERATIVO,
        VERSION_SISTEMA_OPERATIVO = p_rows_tab(i).VERSION_SISTEMA_OPERATIVO,
        TIPO                      = p_rows_tab(i).TIPO,
        NOMBRE_NAVEGADOR          = p_rows_tab(i).NOMBRE_NAVEGADOR,
        VERSION_NAVEGADOR         = p_rows_tab(i).VERSION_NAVEGADOR,
        TOKEN_NOTIFICACION        = p_rows_tab(i).TOKEN_NOTIFICACION,
        VERSION_APLICACION        = p_rows_tab(i).VERSION_APLICACION,
        ID_PAIS                   = p_rows_tab(i).ID_PAIS /*FK*/,
        ZONA_HORARIA              = p_rows_tab(i).ZONA_HORARIA,
        ID_IDIOMA                 = p_rows_tab(i).ID_IDIOMA /*FK*/,
        USUARIO_MODIFICACION      = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
        FECHA_MODIFICACION        = systimestamp
      WHERE
        ID_DISPOSITIVO = p_rows_tab(i).ID_DISPOSITIVO;
  END update_rows;

  PROCEDURE delete_row (
    p_id_dispositivo IN T_DISPOSITIVOS.ID_DISPOSITIVO%TYPE /*PK*/ )
  IS
  BEGIN
    DELETE FROM T_DISPOSITIVOS
    WHERE
      ID_DISPOSITIVO = p_id_dispositivo;
  END delete_row;

  PROCEDURE delete_rows (
    p_rows_tab IN t_rows_tab )
  IS
  BEGIN
    FORALL i IN INDICES OF p_rows_tab
      DELETE FROM T_DISPOSITIVOS
       WHERE ID_DISPOSITIVO = p_rows_tab(i).ID_DISPOSITIVO;
  END delete_rows;

  FUNCTION create_or_update_row (
    p_id_dispositivo            IN T_DISPOSITIVOS.ID_DISPOSITIVO%TYPE DEFAULT NULL /*PK*/,
    p_token_dispositivo         IN T_DISPOSITIVOS.TOKEN_DISPOSITIVO%TYPE /*UK*/,
    p_fecha_ultimo_acceso       IN T_DISPOSITIVOS.FECHA_ULTIMO_ACCESO%TYPE,
    p_id_aplicacion             IN T_DISPOSITIVOS.ID_APLICACION%TYPE /*FK*/,
    p_nombre_sistema_operativo  IN T_DISPOSITIVOS.NOMBRE_SISTEMA_OPERATIVO%TYPE,
    p_version_sistema_operativo IN T_DISPOSITIVOS.VERSION_SISTEMA_OPERATIVO%TYPE,
    p_tipo                      IN T_DISPOSITIVOS.TIPO%TYPE,
    p_nombre_navegador          IN T_DISPOSITIVOS.NOMBRE_NAVEGADOR%TYPE,
    p_version_navegador         IN T_DISPOSITIVOS.VERSION_NAVEGADOR%TYPE,
    p_token_notificacion        IN T_DISPOSITIVOS.TOKEN_NOTIFICACION%TYPE,
    p_version_aplicacion        IN T_DISPOSITIVOS.VERSION_APLICACION%TYPE,
    p_id_pais                   IN T_DISPOSITIVOS.ID_PAIS%TYPE /*FK*/,
    p_zona_horaria              IN T_DISPOSITIVOS.ZONA_HORARIA%TYPE,
    p_id_idioma                 IN T_DISPOSITIVOS.ID_IDIOMA%TYPE /*FK*/ )
  RETURN T_DISPOSITIVOS.ID_DISPOSITIVO%TYPE
  IS
  BEGIN
    IF row_exists(
      p_id_dispositivo => p_id_dispositivo
    )
    THEN
      RETURN update_row (
        p_id_dispositivo            => p_id_dispositivo /*PK*/,
        p_token_dispositivo         => p_token_dispositivo /*UK*/,
        p_fecha_ultimo_acceso       => p_fecha_ultimo_acceso,
        p_id_aplicacion             => p_id_aplicacion /*FK*/,
        p_nombre_sistema_operativo  => p_nombre_sistema_operativo,
        p_version_sistema_operativo => p_version_sistema_operativo,
        p_tipo                      => p_tipo,
        p_nombre_navegador          => p_nombre_navegador,
        p_version_navegador         => p_version_navegador,
        p_token_notificacion        => p_token_notificacion,
        p_version_aplicacion        => p_version_aplicacion,
        p_id_pais                   => p_id_pais /*FK*/,
        p_zona_horaria              => p_zona_horaria,
        p_id_idioma                 => p_id_idioma /*FK*/ );
    ELSE
      RETURN create_row (
        p_id_dispositivo            => p_id_dispositivo /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_token_dispositivo         => p_token_dispositivo /*UK*/,
        p_fecha_ultimo_acceso       => p_fecha_ultimo_acceso,
        p_id_aplicacion             => p_id_aplicacion /*FK*/,
        p_nombre_sistema_operativo  => p_nombre_sistema_operativo,
        p_version_sistema_operativo => p_version_sistema_operativo,
        p_tipo                      => p_tipo,
        p_nombre_navegador          => p_nombre_navegador,
        p_version_navegador         => p_version_navegador,
        p_token_notificacion        => p_token_notificacion,
        p_version_aplicacion        => p_version_aplicacion,
        p_id_pais                   => p_id_pais /*FK*/,
        p_zona_horaria              => p_zona_horaria,
        p_id_idioma                 => p_id_idioma /*FK*/ );
    END IF;
  END create_or_update_row;

