    p_version_sistema_operativo IN T_DISPOSITIVOS.VERSION_SISTEMA_OPERATIVO%TYPE,
    p_tipo                      IN T_DISPOSITIVOS.TIPO%TYPE,
    p_nombre_navegador          IN T_DISPOSITIVOS.NOMBRE_NAVEGADOR%TYPE,
    p_version_navegador         IN T_DISPOSITIVOS.VERSION_NAVEGADOR%TYPE,
    p_token_notificacion        IN T_DISPOSITIVOS.TOKEN_NOTIFICACION%TYPE,
    p_version_aplicacion        IN T_DISPOSITIVOS.VERSION_APLICACION%TYPE,
    p_id_pais                   IN T_DISPOSITIVOS.ID_PAIS%TYPE /*FK*/,
    p_zona_horaria              IN T_DISPOSITIVOS.ZONA_HORARIA%TYPE,
    p_id_idioma                 IN T_DISPOSITIVOS.ID_IDIOMA%TYPE /*FK*/ )
  RETURN T_DISPOSITIVOS.ID_DISPOSITIVO%TYPE
  IS
    v_return T_DISPOSITIVOS.ID_DISPOSITIVO%TYPE; 
  BEGIN
    UPDATE
      T_DISPOSITIVOS
    SET
      TOKEN_DISPOSITIVO         = p_token_dispositivo /*UK*/,
      FECHA_ULTIMO_ACCESO       = p_fecha_ultimo_acceso,
      ID_APLICACION             = p_id_aplicacion /*FK*/,
      NOMBRE_SISTEMA_OPERATIVO  = p_nombre_sistema_operativo,
      VERSION_SISTEMA_OPERATIVO = p_version_sistema_operativo,
      TIPO                      = p_tipo,
      NOMBRE_NAVEGADOR          = p_nombre_navegador,
      VERSION_NAVEGADOR         = p_version_navegador,
      TOKEN_NOTIFICACION        = p_token_notificacion,
      VERSION_APLICACION        = p_version_aplicacion,
      ID_PAIS                   = p_id_pais /*FK*/,
      ZONA_HORARIA              = p_zona_horaria,
      ID_IDIOMA                 = p_id_idioma /*FK*/,
      USUARIO_MODIFICACION      = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION        = systimestamp
    WHERE
      ID_DISPOSITIVO = p_id_dispositivo
    RETURN 
