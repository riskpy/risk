  PROCEDURE set_token_dispositivo (
    p_id_dispositivo    IN T_DISPOSITIVOS.ID_DISPOSITIVO%TYPE /*PK*/,
    p_token_dispositivo IN T_DISPOSITIVOS.TOKEN_DISPOSITIVO%TYPE )
  IS
  BEGIN
    UPDATE
      T_DISPOSITIVOS
    SET
      TOKEN_DISPOSITIVO    = p_token_dispositivo /*UK*/,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_DISPOSITIVO = p_id_dispositivo;
  END set_token_dispositivo;

