    p_nombre_programa_implementacion IN T_OPERACIONES.NOMBRE_PROGRAMA_IMPLEMENTACION%TYPE )
  RETURN T_OPERACIONES.ID_OPERACION%TYPE
  IS
    v_return T_OPERACIONES.ID_OPERACION%TYPE; 
  BEGIN
    UPDATE
      T_OPERACIONES
    SET
      TIPO                           = p_tipo /*UK*/,
      NOMBRE                         = p_nombre /*UK*/,
      DOMINIO                        = p_dominio /*UK*/ /*FK*/,
      ACTIVO                         = p_activo,
      DETALLE                        = p_detalle,
      VERSION_ACTUAL                 = p_version_actual,
      NIVEL_LOG                      = p_nivel_log,
      PARAMETROS_AUTOMATICOS         = p_parametros_automaticos,
