  PROCEDURE set_tipo (
    p_id_operacion IN T_OPERACIONES.ID_OPERACION%TYPE /*PK*/,
    p_tipo         IN T_OPERACIONES.TIPO%TYPE )
  IS
  BEGIN
    UPDATE
      T_OPERACIONES
    SET
      TIPO                 = p_tipo /*UK*/,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_OPERACION = p_id_operacion;
  END set_tipo;

