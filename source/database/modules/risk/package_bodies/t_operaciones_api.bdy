  FUNCTION read_row (
    p_id_operacion IN T_OPERACIONES.ID_OPERACION%TYPE /*PK*/ )
  RETURN T_OPERACIONES%ROWTYPE
  IS
    v_row T_OPERACIONES%ROWTYPE;
    CURSOR cur_row IS
      SELECT * FROM T_OPERACIONES
      WHERE
        ID_OPERACION = p_id_operacion;
  BEGIN
    OPEN cur_row;
    FETCH cur_row INTO v_row;
    CLOSE cur_row;
    RETURN v_row;
  END read_row;

  FUNCTION read_row (
    p_tipo    IN T_OPERACIONES.TIPO%TYPE /*UK*/,
    p_nombre  IN T_OPERACIONES.NOMBRE%TYPE /*UK*/,
    p_dominio IN T_OPERACIONES.DOMINIO%TYPE /*UK*/ )
  RETURN T_OPERACIONES%ROWTYPE
  IS
    v_row T_OPERACIONES%ROWTYPE;
    CURSOR cur_row IS
      SELECT *
        FROM T_OPERACIONES
       WHERE TIPO = p_tipo
        AND NOMBRE = p_nombre
        AND COALESCE(DOMINIO, '@@@@@@@@@@@@@@@') = COALESCE(p_dominio, '@@@@@@@@@@@@@@@');
  BEGIN
    OPEN cur_row;
    FETCH cur_row INTO v_row;
    CLOSE cur_row;
    RETURN v_row;
  END;

  PROCEDURE read_row (
    p_id_operacion                   IN            T_OPERACIONES.ID_OPERACION%TYPE /*PK*/,
    p_tipo                              OUT NOCOPY T_OPERACIONES.TIPO%TYPE /*UK*/,
    p_nombre                            OUT NOCOPY T_OPERACIONES.NOMBRE%TYPE /*UK*/,
    p_dominio                           OUT NOCOPY T_OPERACIONES.DOMINIO%TYPE /*UK*/ /*FK*/,
    p_activo                            OUT NOCOPY T_OPERACIONES.ACTIVO%TYPE,
    p_detalle                           OUT NOCOPY T_OPERACIONES.DETALLE%TYPE,
    p_version_actual                    OUT NOCOPY T_OPERACIONES.VERSION_ACTUAL%TYPE,
    p_nivel_log                         OUT NOCOPY T_OPERACIONES.NIVEL_LOG%TYPE,
    p_parametros_automaticos            OUT NOCOPY T_OPERACIONES.PARAMETROS_AUTOMATICOS%TYPE,
    p_tipo_implementacion               OUT NOCOPY T_OPERACIONES.TIPO_IMPLEMENTACION%TYPE,
    p_aplicaciones_permitidas           OUT NOCOPY T_OPERACIONES.APLICACIONES_PERMITIDAS%TYPE,
    p_nombre_programa_implementacion    OUT NOCOPY T_OPERACIONES.NOMBRE_PROGRAMA_IMPLEMENTACION%TYPE,
    p_usuario_insercion                 OUT NOCOPY T_OPERACIONES.USUARIO_INSERCION%TYPE,
    p_fecha_insercion                   OUT NOCOPY T_OPERACIONES.FECHA_INSERCION%TYPE,
    p_usuario_modificacion              OUT NOCOPY T_OPERACIONES.USUARIO_MODIFICACION%TYPE,
    p_fecha_modificacion                OUT NOCOPY T_OPERACIONES.FECHA_MODIFICACION%TYPE )
  IS
    v_row T_OPERACIONES%ROWTYPE;
  BEGIN
    v_row := read_row (
      p_id_operacion => p_id_operacion );
    p_tipo                           := v_row.TIPO; 
    p_nombre                         := v_row.NOMBRE; 
    p_dominio                        := v_row.DOMINIO; 
    p_activo                         := v_row.ACTIVO; 
    p_detalle                        := v_row.DETALLE; 
    p_version_actual                 := v_row.VERSION_ACTUAL; 
    p_nivel_log                      := v_row.NIVEL_LOG; 
    p_parametros_automaticos         := v_row.PARAMETROS_AUTOMATICOS; 
    p_tipo_implementacion            := v_row.TIPO_IMPLEMENTACION; 
    p_aplicaciones_permitidas        := v_row.APLICACIONES_PERMITIDAS; 
    p_nombre_programa_implementacion := v_row.NOMBRE_PROGRAMA_IMPLEMENTACION; 
    p_usuario_insercion              := v_row.USUARIO_INSERCION; 
    p_fecha_insercion                := v_row.FECHA_INSERCION; 
    p_usuario_modificacion           := v_row.USUARIO_MODIFICACION; 
    p_fecha_modificacion             := v_row.FECHA_MODIFICACION; 
  END read_row;

  FUNCTION read_rows (
    p_ref_cursor IN t_strong_ref_cursor )
  RETURN t_rows_tab
  IS
    v_return t_rows_tab;
  BEGIN
    IF (p_ref_cursor%ISOPEN) THEN
      g_bulk_completed := FALSE;
      FETCH p_ref_cursor BULK COLLECT INTO v_return LIMIT g_bulk_limit;
      IF (v_return.COUNT < g_bulk_limit) THEN
        g_bulk_completed := TRUE;
      END IF;
    END IF;
    RETURN v_return;
  END read_rows;

