        TIPO_IMPLEMENTACION            = p_rows_tab(i).TIPO_IMPLEMENTACION,
        APLICACIONES_PERMITIDAS        = p_rows_tab(i).APLICACIONES_PERMITIDAS,
        NOMBRE_PROGRAMA_IMPLEMENTACION = p_rows_tab(i).NOMBRE_PROGRAMA_IMPLEMENTACION,
        USUARIO_MODIFICACION           = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
        FECHA_MODIFICACION             = systimestamp
      WHERE
        ID_OPERACION = p_rows_tab(i).ID_OPERACION;
  END update_rows;

  PROCEDURE delete_row (
    p_id_operacion IN T_OPERACIONES.ID_OPERACION%TYPE /*PK*/ )
  IS
  BEGIN
    DELETE FROM T_OPERACIONES
    WHERE
      ID_OPERACION = p_id_operacion;
  END delete_row;

  PROCEDURE delete_rows (
    p_rows_tab IN t_rows_tab )
  IS
  BEGIN
    FORALL i IN INDICES OF p_rows_tab
      DELETE FROM T_OPERACIONES
       WHERE ID_OPERACION = p_rows_tab(i).ID_OPERACION;
  END delete_rows;

  FUNCTION create_or_update_row (
    p_id_operacion                   IN T_OPERACIONES.ID_OPERACION%TYPE DEFAULT NULL /*PK*/,
    p_tipo                           IN T_OPERACIONES.TIPO%TYPE /*UK*/,
    p_nombre                         IN T_OPERACIONES.NOMBRE%TYPE /*UK*/,
    p_dominio                        IN T_OPERACIONES.DOMINIO%TYPE /*UK*/ /*FK*/,
    p_activo                         IN T_OPERACIONES.ACTIVO%TYPE,
    p_detalle                        IN T_OPERACIONES.DETALLE%TYPE,
    p_version_actual                 IN T_OPERACIONES.VERSION_ACTUAL%TYPE,
    p_nivel_log                      IN T_OPERACIONES.NIVEL_LOG%TYPE,
    p_parametros_automaticos         IN T_OPERACIONES.PARAMETROS_AUTOMATICOS%TYPE,
    p_tipo_implementacion            IN T_OPERACIONES.TIPO_IMPLEMENTACION%TYPE,
    p_aplicaciones_permitidas        IN T_OPERACIONES.APLICACIONES_PERMITIDAS%TYPE,
    p_nombre_programa_implementacion IN T_OPERACIONES.NOMBRE_PROGRAMA_IMPLEMENTACION%TYPE )
  RETURN T_OPERACIONES.ID_OPERACION%TYPE
  IS
  BEGIN
    IF row_exists(
      p_id_operacion => p_id_operacion
    )
    THEN
      RETURN update_row (
        p_id_operacion                   => p_id_operacion /*PK*/,
        p_tipo                           => p_tipo /*UK*/,
        p_nombre                         => p_nombre /*UK*/,
        p_dominio                        => p_dominio /*UK*/ /*FK*/,
        p_activo                         => p_activo,
        p_detalle                        => p_detalle,
        p_version_actual                 => p_version_actual,
        p_nivel_log                      => p_nivel_log,
        p_parametros_automaticos         => p_parametros_automaticos,
        p_tipo_implementacion            => p_tipo_implementacion,
        p_aplicaciones_permitidas        => p_aplicaciones_permitidas,
        p_nombre_programa_implementacion => p_nombre_programa_implementacion );
    ELSE
      RETURN create_row (
        p_id_operacion                   => p_id_operacion /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_tipo                           => p_tipo /*UK*/,
        p_nombre                         => p_nombre /*UK*/,
        p_dominio                        => p_dominio /*UK*/ /*FK*/,
        p_activo                         => p_activo,
        p_detalle                        => p_detalle,
        p_version_actual                 => p_version_actual,
        p_nivel_log                      => p_nivel_log,
        p_parametros_automaticos         => p_parametros_automaticos,
        p_tipo_implementacion            => p_tipo_implementacion,
        p_aplicaciones_permitidas        => p_aplicaciones_permitidas,
        p_nombre_programa_implementacion => p_nombre_programa_implementacion );
    END IF;
  END create_or_update_row;

