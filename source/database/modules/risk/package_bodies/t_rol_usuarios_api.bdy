  PROCEDURE set_id_rol (
    p_id_rol_usuario IN T_ROL_USUARIOS.ID_ROL_USUARIO%TYPE /*PK*/,
    p_id_rol         IN T_ROL_USUARIOS.ID_ROL%TYPE )
  IS
  BEGIN
    UPDATE
      T_ROL_USUARIOS
    SET
      ID_ROL               = p_id_rol /*UK*/ /*FK*/,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_ROL_USUARIO = p_id_rol_usuario;
  END set_id_rol;

  PROCEDURE set_id_usuario (
    p_id_rol_usuario IN T_ROL_USUARIOS.ID_ROL_USUARIO%TYPE /*PK*/,
    p_id_usuario     IN T_ROL_USUARIOS.ID_USUARIO%TYPE )
  IS
  BEGIN
    UPDATE
      T_ROL_USUARIOS
    SET
      ID_USUARIO           = p_id_usuario /*UK*/ /*FK*/,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_ROL_USUARIO = p_id_rol_usuario;
  END set_id_usuario;

  PROCEDURE set_id_entidad (
