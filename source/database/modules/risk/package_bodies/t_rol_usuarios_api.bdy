  END set_id_entidad;

  PROCEDURE set_grupo (
    p_id_rol_usuario IN T_ROL_USUARIOS.ID_ROL_USUARIO%TYPE /*PK*/,
    p_grupo          IN T_ROL_USUARIOS.GRUPO%TYPE )
  IS
  BEGIN
    UPDATE
      T_ROL_USUARIOS
    SET
      GRUPO                = p_grupo /*UK*/ /*FK*/,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
