create table T_DISPOSITIVO_UBICACIONES
(
  id_dispositivo       NUMBER not null,
  orden                NUMBER(3) not null,
  fecha                DATE not null,
  latitud              NUMBER not null,
  longitud             NUMBER not null,
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_DISPOSITIVO_UBICACIONES
  is 'Ubicaciones de Dispositivos';
comment on column T_DISPOSITIVO_UBICACIONES.id_dispositivo
  is 'Identificador del dispositivo';
comment on column T_DISPOSITIVO_UBICACIONES.orden
  is 'Número de orden de la ubicación';
comment on column T_DISPOSITIVO_UBICACIONES.fecha
  is 'Fecha de la ubicación';
comment on column T_DISPOSITIVO_UBICACIONES.latitud
  is 'Latitud de la ubicación';
comment on column T_DISPOSITIVO_UBICACIONES.longitud
  is 'Longitud de la ubicación';
comment on column T_DISPOSITIVO_UBICACIONES.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_DISPOSITIVO_UBICACIONES.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_DISPOSITIVO_UBICACIONES.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_DISPOSITIVO_UBICACIONES.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_DISPOSITIVO_UBICACIONES
  add constraint PK_DISPOSITIVO_UBICACIONES primary key (ID_DISPOSITIVO, ORDEN);

