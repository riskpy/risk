create table T_ROLES
(
  id_rol               NUMBER generated by default on null as identity,
  nombre               VARCHAR2(100),
  activo               VARCHAR2(1) default 'N' not null,
  detalle              VARCHAR2(2000),
  origen               VARCHAR2(1),
  id_externo           VARCHAR2(500),
  implicito            VARCHAR2(1) default 'N' not null,
  direccion_correo     VARCHAR2(320),
  numero_telefono      VARCHAR2(160),
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_ROLES
  is 'Roles';
comment on column T_ROLES.id_rol
  is 'Identificador del rol';
comment on column T_ROLES.nombre
  is 'Nombre del rol';
comment on column T_ROLES.activo
  is 'El rol esta activo? (S-Sí/N-No)';
comment on column T_ROLES.detalle
  is 'Detalles adicionales del rol';
comment on column T_ROLES.origen
  is 'Origen del rol';
comment on column T_ROLES.id_externo
  is 'Identificador externo del rol';
comment on column T_ROLES.implicito
  is 'El rol es implícito? (S-Sí/N-No)';
comment on column T_ROLES.direccion_correo
  is 'Direccion de correo electronico del rol';
comment on column T_ROLES.numero_telefono
  is 'Numero de telefono del rol';
comment on column T_ROLES.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_ROLES.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_ROLES.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_ROLES.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
create index IDX_ROLES_ID_EXTERNO on T_ROLES (ID_EXTERNO);
create index IDX_ROLES_ORIGEN on T_ROLES (ORIGEN);
alter table T_ROLES
  add constraint PK_ROLES primary key (ID_ROL);
alter table T_ROLES
  add constraint UK_ROLES_NOMBRE unique (NOMBRE);
alter table T_ROLES
  add constraint CK_ROLES_ACTIVO
  check (ACTIVO IN ('S', 'N'));
alter table T_ROLES
  add constraint CK_ROLES_IMPLICITO
  check (IMPLICITO IN ('S', 'N'));

