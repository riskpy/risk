create table T_ERRORES
(
  id_error             NUMBER generated by default on null as identity (nocache),
  clave                VARCHAR2(100) not null,
  mensaje              VARCHAR2(4000),
  id_dominio           VARCHAR2(30),
  id_idioma            NUMBER,
  id_pais              NUMBER,
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_ERRORES
  is 'Errores o textos';
comment on column T_ERRORES.id_error
  is 'Identificador del error o texto';
comment on column T_ERRORES.clave
  is 'Clave del error o texto';
comment on column T_ERRORES.mensaje
  is 'Mensaje del error o texto';
comment on column T_ERRORES.id_dominio
  is 'Dominio del error o texto';
comment on column T_ERRORES.id_idioma
  is 'Idioma del error o texto';
comment on column T_ERRORES.id_pais
  is 'País del error o texto';
comment on column T_ERRORES.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_ERRORES.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_ERRORES.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_ERRORES.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_ERRORES
  add constraint PK_ERRORES primary key (ID_ERROR);
alter table T_ERRORES
  add constraint UK_ERRORES unique (CLAVE, ID_IDIOMA, ID_PAIS);

