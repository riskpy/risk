create table T_DOMINIOS
(
  id_dominio           VARCHAR2(30) not null,
  nombre               VARCHAR2(100) not null,
  detalle              VARCHAR2(2000),
  activo               VARCHAR2(1) default 'N' not null,
  id_modulo            VARCHAR2(30) not null,
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_DOMINIOS
  is 'Dominios';
comment on column T_DOMINIOS.id_dominio
  is 'Identificador del dominio';
comment on column T_DOMINIOS.nombre
  is 'Nombre del dominio';
comment on column T_DOMINIOS.detalle
  is 'Detalles adicionales del dominio';
comment on column T_DOMINIOS.activo
  is 'El dominio está activo? (S/N)';
comment on column T_DOMINIOS.id_modulo
  is 'Módulo del dominio';
comment on column T_DOMINIOS.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_DOMINIOS.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_DOMINIOS.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_DOMINIOS.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_DOMINIOS
  add constraint PK_DOMINIOS primary key (ID_DOMINIO);
alter table T_DOMINIOS
  add constraint CK_DOMINIOS_ACTIVO
  check (ACTIVO IN ('S', 'N'));

