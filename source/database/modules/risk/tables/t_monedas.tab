create table T_MONEDAS
(
  id_moneda            VARCHAR2(3) not null,
  descripcion          VARCHAR2(50) not null,
  activo               VARCHAR2(1) default 'N' not null,
  formato              VARCHAR2(30),
  simbolo              VARCHAR2(10),
  id_pais              NUMBER,
  codigo_iso           VARCHAR2(3),
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_MONEDAS
  is 'Monedas';
comment on column T_MONEDAS.id_moneda
  is 'Identificador de la moneda';
comment on column T_MONEDAS.descripcion
  is 'Descripción de la moneda';
comment on column T_MONEDAS.activo
  is 'La moneda está activa? (S/N)';
comment on column T_MONEDAS.formato
  is 'Formato de la moneda';
comment on column T_MONEDAS.simbolo
  is 'Símbolo de la moneda';
comment on column T_MONEDAS.id_pais
  is 'País de la moneda';
comment on column T_MONEDAS.codigo_iso
  is 'Código de la moneda según estándar ISO 4217';
comment on column T_MONEDAS.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_MONEDAS.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_MONEDAS.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_MONEDAS.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_MONEDAS
  add constraint PK_MONEDAS primary key (ID_MONEDA);
alter table T_MONEDAS
  add constraint CK_MONEDAS_ACTIVO
  check (ACTIVO IN ('S', 'N'));

