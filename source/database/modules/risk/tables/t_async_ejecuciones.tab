create table T_ASYNC_EJECUCIONES
(
  id_async_ejecucion   NUMBER generated by default on null as identity,
  descripcion          VARCHAR2(500),
  nombre_job           VARCHAR2(300),
  estado               VARCHAR2(1),
  bloque_plsql         CLOB,
  fecha_hora_inicio    TIMESTAMP(3),
  fecha_hora_fin       TIMESTAMP(3),
  duracion             INTERVAL DAY(3) TO SECOND(3),
  detalle              VARCHAR2(4000),
  referencia           VARCHAR2(500),
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_ASYNC_EJECUCIONES
  is 'Ejecuciones asíncronas de procesos';
comment on column T_ASYNC_EJECUCIONES.id_async_ejecucion
  is 'Identificador de la ejecución asíncrona';
comment on column T_ASYNC_EJECUCIONES.descripcion
  is 'Descripción del proceso';
comment on column T_ASYNC_EJECUCIONES.nombre_job
  is 'Nombre del job relacionado';
comment on column T_ASYNC_EJECUCIONES.estado
  is 'Estado de la ejecución asíncrona';
comment on column T_ASYNC_EJECUCIONES.bloque_plsql
  is 'Bloque PL/SQL de la ejecución asíncrona';
comment on column T_ASYNC_EJECUCIONES.fecha_hora_inicio
  is 'Fecha/hora de inicio de la ejecución asíncrona';
comment on column T_ASYNC_EJECUCIONES.fecha_hora_fin
  is 'Fecha/hora de fin de la ejecución asíncrona';
comment on column T_ASYNC_EJECUCIONES.duracion
  is 'Duración de la ejecución asíncrona';
comment on column T_ASYNC_EJECUCIONES.detalle
  is 'Detalle de la ejecución asíncrona';
comment on column T_ASYNC_EJECUCIONES.referencia
  is 'Identificador del registro relacionado';
comment on column T_ASYNC_EJECUCIONES.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_ASYNC_EJECUCIONES.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_ASYNC_EJECUCIONES.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_ASYNC_EJECUCIONES.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
create index IDX_ASYNC_EJECUCIONES_DESCRIPCION on T_ASYNC_EJECUCIONES (DESCRIPCION);
create index IDX_ASYNC_EJECUCIONES_REFERENCIA on T_ASYNC_EJECUCIONES (REFERENCIA);
alter table T_ASYNC_EJECUCIONES
  add constraint PK_ASYNC_EJECUCIONES primary key (ID_ASYNC_EJECUCION);

