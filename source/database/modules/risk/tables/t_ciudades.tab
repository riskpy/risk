create table T_CIUDADES
(
  id_ciudad            NUMBER generated by default on null as identity (nocache),
  nombre               VARCHAR2(100),
  id_pais              NUMBER,
  id_departamento      NUMBER,
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_CIUDADES
  is 'Ciudades';
comment on column T_CIUDADES.id_ciudad
  is 'Identificador de la ciudad';
comment on column T_CIUDADES.nombre
  is 'Nombre de la ciudad';
comment on column T_CIUDADES.id_pais
  is 'País de la ciudad';
comment on column T_CIUDADES.id_departamento
  is 'Departamento, estado o provincia de la ciudad';
comment on column T_CIUDADES.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_CIUDADES.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_CIUDADES.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_CIUDADES.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_CIUDADES
  add constraint PK_CIUDADES primary key (ID_CIUDAD);

