create table T_DOCUMENTO_TIPOS
(
  id_documento_tipo    VARCHAR2(3) not null,
  nombre               VARCHAR2(100) not null,
  detalle              VARCHAR2(2000),
  activo               VARCHAR2(1) default 'N' not null,
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_DOCUMENTO_TIPOS
  is 'Tipos de documentos';
comment on column T_DOCUMENTO_TIPOS.id_documento_tipo
  is 'Identificador del tipo de documento';
comment on column T_DOCUMENTO_TIPOS.nombre
  is 'Nombre del tipo de documento';
comment on column T_DOCUMENTO_TIPOS.detalle
  is 'Detalles adicionales del tipo de documento';
comment on column T_DOCUMENTO_TIPOS.activo
  is 'El tipo de documento está activo? (S/N)';
comment on column T_DOCUMENTO_TIPOS.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_DOCUMENTO_TIPOS.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_DOCUMENTO_TIPOS.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_DOCUMENTO_TIPOS.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_DOCUMENTO_TIPOS
  add constraint PK_DOCUMENTO_TIPOS primary key (ID_DOCUMENTO_TIPO);
alter table T_DOCUMENTO_TIPOS
  add constraint CK_DOCUMENTO_TIPOS_ACTIVO
  check (ACTIVO IN ('S', 'N'));

