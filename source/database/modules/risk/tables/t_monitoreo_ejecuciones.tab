create table T_MONITOREO_EJECUCIONES
(
  id_monitoreo_ejecucion NUMBER generated by default on null as identity,
  id_monitoreo           NUMBER not null,
  fecha_inicio_ejecucion TIMESTAMP(2) WITH TIME ZONE not null,
  fecha_fin_ejecucion    TIMESTAMP(2) WITH TIME ZONE not null,
  duracion               INTERVAL DAY(2) TO SECOND(2),
  datos                  CLOB,
  usuario_insercion      VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion        TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion   VARCHAR2(300),
  fecha_modificacion     TIMESTAMP(2)
)
;
comment on table T_MONITOREO_EJECUCIONES
  is 'Ejecuciones de monitoreos de conflictos';
comment on column T_MONITOREO_EJECUCIONES.id_monitoreo_ejecucion
  is 'Identificador de la ejecuciµn';
comment on column T_MONITOREO_EJECUCIONES.id_monitoreo
  is 'Identificador del monitoreo';
comment on column T_MONITOREO_EJECUCIONES.fecha_inicio_ejecucion
  is 'Fecha de inicio de la ejecuciµn del monitoreo';
comment on column T_MONITOREO_EJECUCIONES.fecha_fin_ejecucion
  is 'Fecha de fin de la ejecuciµn del monitoreo';
comment on column T_MONITOREO_EJECUCIONES.duracion
  is 'Duraciµn de la ejecucion del monitoreo';
comment on column T_MONITOREO_EJECUCIONES.datos
  is 'Datos del conflicto';
comment on column T_MONITOREO_EJECUCIONES.usuario_insercion
  is 'Usuario que realizµ la creaciµn del registro';
comment on column T_MONITOREO_EJECUCIONES.fecha_insercion
  is 'Fecha en que se realizµ la creaciµn del registro';
comment on column T_MONITOREO_EJECUCIONES.usuario_modificacion
  is 'Usuario que realizµ la ºltima ediciµn del registro';
comment on column T_MONITOREO_EJECUCIONES.fecha_modificacion
  is 'Fecha en que se realizµ la ºltima ediciµn del registro';
alter table T_MONITOREO_EJECUCIONES
  add constraint PK_MONITOREO_EJECUCIONES primary key (ID_MONITOREO_EJECUCION);

