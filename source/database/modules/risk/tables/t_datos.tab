create table T_DATOS
(
  tabla                VARCHAR2(50) not null,
  campo                VARCHAR2(50) not null,
  referencia           VARCHAR2(500) not null,
  contenido            VARCHAR2(4000),
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_DATOS
  is 'Datos adicionales';
comment on column T_DATOS.tabla
  is 'Nombre de la tabla relacionada';
comment on column T_DATOS.campo
  is 'Nombre del campo';
comment on column T_DATOS.referencia
  is 'Identificador del registro relacionado';
comment on column T_DATOS.contenido
  is 'Contenido del dato adicional';
comment on column T_DATOS.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_DATOS.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_DATOS.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_DATOS.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_DATOS
  add constraint PK_DATOS primary key (TABLA, CAMPO, REFERENCIA);

