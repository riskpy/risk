create table T_SIGNIFICADOS
(
  dominio              VARCHAR2(50) not null,
  codigo               VARCHAR2(50) not null,
  significado          VARCHAR2(500),
  referencia           VARCHAR2(500),
  activo               VARCHAR2(1) default 'N' not null,
  referencia_2         VARCHAR2(500),
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_SIGNIFICADOS
  is 'Significados';
comment on column T_SIGNIFICADOS.dominio
  is 'Dominio de significados';
comment on column T_SIGNIFICADOS.codigo
  is 'Codigo';
comment on column T_SIGNIFICADOS.significado
  is 'Significado';
comment on column T_SIGNIFICADOS.referencia
  is 'Referencia adicional';
comment on column T_SIGNIFICADOS.activo
  is 'El significado esta activo? (S/N)';
comment on column T_SIGNIFICADOS.referencia_2
  is 'Referencia adicional 2';
comment on column T_SIGNIFICADOS.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_SIGNIFICADOS.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_SIGNIFICADOS.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_SIGNIFICADOS.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_SIGNIFICADOS
  add constraint PK_SIGNIFICADOS primary key (DOMINIO, CODIGO);
alter table T_SIGNIFICADOS
  add constraint CK_SIGNIFICADOS_ACTIVO
  check (ACTIVO IN ('S', 'N'));

