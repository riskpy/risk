create table T_DATO_DEFINICIONES
(
  tabla                VARCHAR2(50) not null,
  campo                VARCHAR2(50) not null,
  descripcion          VARCHAR2(500),
  orden                NUMBER(3) not null,
  nombre_referencia    VARCHAR2(50),
  tipo_dato            VARCHAR2(1) not null,
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_DATO_DEFINICIONES
  is 'Definiciones de Datos adicionales';
comment on column T_DATO_DEFINICIONES.tabla
  is 'Nombre de la tabla relacionada';
comment on column T_DATO_DEFINICIONES.campo
  is 'Nombre del campo';
comment on column T_DATO_DEFINICIONES.descripcion
  is 'Descripción del dato adicional';
comment on column T_DATO_DEFINICIONES.orden
  is 'Número de orden del campo';
comment on column T_DATO_DEFINICIONES.nombre_referencia
  is 'Nombre del campo de referencia';
comment on column T_DATO_DEFINICIONES.tipo_dato
  is 'Tipo de dato';
comment on column T_DATO_DEFINICIONES.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_DATO_DEFINICIONES.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_DATO_DEFINICIONES.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_DATO_DEFINICIONES.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_DATO_DEFINICIONES
  add constraint PK_DATO_DEFINICIONES primary key (TABLA, CAMPO);
alter table T_DATO_DEFINICIONES
  add constraint CK_DATO_DEFINICIONES_TIPO_DATO
  check (TIPO_DATO IN ('S', 'N', 'B', 'D'));

