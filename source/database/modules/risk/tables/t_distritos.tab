create table T_DISTRITOS
(
  id_distrito          NUMBER generated by default on null as identity,
  nombre               VARCHAR2(100),
  id_pais              NUMBER,
  id_departamento      NUMBER,
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_DISTRITOS
  is 'Distritos o zonas';
comment on column T_DISTRITOS.id_distrito
  is 'Identificador del distrito o zona';
comment on column T_DISTRITOS.nombre
  is 'Nombre del distrito o zona';
comment on column T_DISTRITOS.id_pais
  is 'País del distrito o zona';
comment on column T_DISTRITOS.id_departamento
  is 'Departamento, estado o provincia del distrito o zona';
comment on column T_DISTRITOS.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_DISTRITOS.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_DISTRITOS.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_DISTRITOS.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_DISTRITOS
  add constraint PK_DISTRITOS primary key (ID_DISTRITO);

