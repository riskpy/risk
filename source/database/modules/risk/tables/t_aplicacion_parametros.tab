create table T_APLICACION_PARAMETROS
(
  id_aplicacion        VARCHAR2(5) not null,
  id_parametro         VARCHAR2(50) not null,
  valor                VARCHAR2(4000),
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_APLICACION_PARAMETROS
  is 'Parametros adicionales de aplicaciones';
comment on column T_APLICACION_PARAMETROS.id_aplicacion
  is 'Identificador de la aplicación';
comment on column T_APLICACION_PARAMETROS.id_parametro
  is 'Identificador del parámetro';
comment on column T_APLICACION_PARAMETROS.valor
  is 'Valor del parámetro';
comment on column T_APLICACION_PARAMETROS.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_APLICACION_PARAMETROS.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_APLICACION_PARAMETROS.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_APLICACION_PARAMETROS.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_APLICACION_PARAMETROS
  add constraint PK_APLICACION_PARAMETROS primary key (ID_APLICACION, ID_PARAMETRO);

