create table T_PERMISOS
(
  id_permiso           VARCHAR2(300) not null,
  descripcion          VARCHAR2(500),
  detalle              VARCHAR2(2000),
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_PERMISOS
  is 'Permisos o recursos';
comment on column T_PERMISOS.id_permiso
  is 'Identificador del permiso o recurso';
comment on column T_PERMISOS.descripcion
  is 'Descripción del permiso o recurso';
comment on column T_PERMISOS.detalle
  is 'Detalles adicionales del permiso o recurso';
comment on column T_PERMISOS.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_PERMISOS.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_PERMISOS.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_PERMISOS.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_PERMISOS
  add constraint PK_PERMISOS primary key (ID_PERMISO);

