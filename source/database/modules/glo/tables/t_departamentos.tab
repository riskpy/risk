create table T_DEPARTAMENTOS
(
  id_departamento      NUMBER generated by default on null as identity (nocache),
  nombre               VARCHAR2(100),
  id_pais              NUMBER,
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_DEPARTAMENTOS
  is 'Departamentos, estados o provincias';
comment on column T_DEPARTAMENTOS.id_departamento
  is 'Identificador del departamento, estado o provincia';
comment on column T_DEPARTAMENTOS.nombre
  is 'Nombre del departamento, estado o provincia';
comment on column T_DEPARTAMENTOS.id_pais
  is 'País del departamento, estado o provincia';
comment on column T_DEPARTAMENTOS.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_DEPARTAMENTOS.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_DEPARTAMENTOS.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_DEPARTAMENTOS.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_DEPARTAMENTOS
  add constraint PK_DEPARTAMENTOS primary key (ID_DEPARTAMENTO);

