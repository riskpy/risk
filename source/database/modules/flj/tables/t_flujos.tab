create table T_FLUJOS
(
  id_flujo             NUMBER generated by default on null as identity (nocache),
  nombre               VARCHAR2(1000) not null,
  activo               VARCHAR2(1) default 'N' not null,
  detalle              VARCHAR2(4000),
  variables_defecto    CLOB,
  usuario_insercion    VARCHAR2(300) default SUBSTR(USER, 1, 300) not null,
  fecha_insercion      TIMESTAMP(2) default SYSTIMESTAMP not null,
  usuario_modificacion VARCHAR2(300),
  fecha_modificacion   TIMESTAMP(2)
)
;
comment on table T_FLUJOS
  is 'Definición de Flujos';
comment on column T_FLUJOS.id_flujo
  is 'Identificador del flujo';
comment on column T_FLUJOS.nombre
  is 'Nombre del flujo';
comment on column T_FLUJOS.activo
  is 'El flujo está activa? (S/N)';
comment on column T_FLUJOS.detalle
  is 'Detalles adicionales de la operación';
comment on column T_FLUJOS.variables_defecto
  is 'Variables por defecto';
comment on column T_FLUJOS.usuario_insercion
  is 'Usuario que realizó la creación del registro';
comment on column T_FLUJOS.fecha_insercion
  is 'Fecha en que se realizó la creación del registro';
comment on column T_FLUJOS.usuario_modificacion
  is 'Usuario que realizó la última edición del registro';
comment on column T_FLUJOS.fecha_modificacion
  is 'Fecha en que se realizó la última edición del registro';
alter table T_FLUJOS
  add constraint PK_FLUJOS primary key (ID_FLUJO);
alter table T_FLUJOS
  add constraint CK_FLUJOS_ACTIVO
  check (ACTIVO IN ('S', 'N'));

