  PROCEDURE set_id_paso_instancia (
    p_id_aprobacion     IN T_FLUJO_INSTANCIA_APROBACIONES.ID_APROBACION%TYPE /*PK*/,
    p_id_paso_instancia IN T_FLUJO_INSTANCIA_APROBACIONES.ID_PASO_INSTANCIA%TYPE )
  IS
  BEGIN
    UPDATE
      T_FLUJO_INSTANCIA_APROBACIONES
    SET
      ID_PASO_INSTANCIA    = p_id_paso_instancia /*FK*/,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_APROBACION = p_id_aprobacion;
  END set_id_paso_instancia;

  PROCEDURE set_usuario_aprobador (
    p_id_aprobacion     IN T_FLUJO_INSTANCIA_APROBACIONES.ID_APROBACION%TYPE /*PK*/,
    p_usuario_aprobador IN T_FLUJO_INSTANCIA_APROBACIONES.USUARIO_APROBADOR%TYPE )
  IS
