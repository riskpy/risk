        p_comentario        => p_comentario,
        p_rol_aprobador     => p_rol_aprobador );
    END IF;
  END create_or_update_row;

  FUNCTION create_or_update_row (
    p_row IN T_FLUJO_INSTANCIA_APROBACIONES%ROWTYPE )
  RETURN T_FLUJO_INSTANCIA_APROBACIONES.ID_APROBACION%TYPE
  IS
  BEGIN
    IF row_exists(
      p_id_aprobacion => p_row.ID_APROBACION
    )
    THEN
      RETURN update_row (
        p_id_aprobacion     => p_row.ID_APROBACION /*PK*/,
        p_id_paso_instancia => p_row.ID_PASO_INSTANCIA /*FK*/,
        p_usuario_aprobador => p_row.USUARIO_APROBADOR,
        p_aprobado          => p_row.APROBADO,
        p_fecha_aprobacion  => p_row.FECHA_APROBACION,
        p_comentario        => p_row.COMENTARIO,
        p_rol_aprobador     => p_row.ROL_APROBADOR );
    ELSE
      RETURN create_row (
        p_id_aprobacion     => p_row.ID_APROBACION /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_id_paso_instancia => p_row.ID_PASO_INSTANCIA /*FK*/,
        p_usuario_aprobador => p_row.USUARIO_APROBADOR,
        p_aprobado          => p_row.APROBADO,
        p_fecha_aprobacion  => p_row.FECHA_APROBACION,
        p_comentario        => p_row.COMENTARIO,
        p_rol_aprobador     => p_row.ROL_APROBADOR );
    END IF;
  END create_or_update_row;

