  PROCEDURE set_fecha_aprobacion (
    p_id_aprobacion    IN T_FLUJO_INSTANCIA_APROBACIONES.ID_APROBACION%TYPE /*PK*/,
    p_fecha_aprobacion IN T_FLUJO_INSTANCIA_APROBACIONES.FECHA_APROBACION%TYPE )
  IS
  BEGIN
    UPDATE
      T_FLUJO_INSTANCIA_APROBACIONES
    SET
      FECHA_APROBACION     = p_fecha_aprobacion,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
