  FUNCTION get_default_row
  RETURN T_FLUJO_INSTANCIA_APROBACIONES%ROWTYPE
  IS
    v_row T_FLUJO_INSTANCIA_APROBACIONES%ROWTYPE;
  BEGIN
    v_row.ID_APROBACION     := NULL /*PK*/;
    v_row.APROBADO          := 'N' ;
    v_row.FECHA_APROBACION  := CURRENT_TIMESTAMP;
    v_row.USUARIO_INSERCION := SUBSTR(USER, 1, 300) ;
    v_row.FECHA_INSERCION   := SYSTIMESTAMP ;
    RETURN v_row;
  END get_default_row;

END T_FLUJO_INSTANCIA_APROBACIONES_API;
