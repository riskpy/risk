  PROCEDURE set_id_flujo (
    p_id_paso  IN T_FLUJO_PASOS.ID_PASO%TYPE /*PK*/,
    p_id_flujo IN T_FLUJO_PASOS.ID_FLUJO%TYPE )
  IS
  BEGIN
    UPDATE
      T_FLUJO_PASOS
    SET
      ID_FLUJO             = p_id_flujo /*FK*/,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_PASO = p_id_paso;
  END set_id_flujo;

  PROCEDURE set_nombre (
    p_id_paso IN T_FLUJO_PASOS.ID_PASO%TYPE /*PK*/,
