    END IF;
  END create_or_update_row;

  FUNCTION create_or_update_row (
    p_row IN T_FLUJO_PASOS%ROWTYPE )
  RETURN T_FLUJO_PASOS.ID_PASO%TYPE
  IS
  BEGIN
    IF row_exists(
      p_id_paso => p_row.ID_PASO
    )
    THEN
      RETURN update_row (
        p_id_paso               => p_row.ID_PASO /*PK*/,
        p_id_flujo              => p_row.ID_FLUJO /*FK*/,
        p_nombre                => p_row.NOMBRE,
        p_tipo                  => p_row.TIPO,
        p_orden                 => p_row.ORDEN,
        p_acciones_posibles     => p_row.ACCIONES_POSIBLES,
        p_bloque_plsql          => p_row.BLOQUE_PLSQL,
        p_roles_responsables    => p_row.ROLES_RESPONSABLES,
        p_usuarios_responsables => p_row.USUARIOS_RESPONSABLES );
    ELSE
      RETURN create_row (
        p_id_paso               => p_row.ID_PASO /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_id_flujo              => p_row.ID_FLUJO /*FK*/,
        p_nombre                => p_row.NOMBRE,
        p_tipo                  => p_row.TIPO,
        p_orden                 => p_row.ORDEN,
        p_acciones_posibles     => p_row.ACCIONES_POSIBLES,
        p_bloque_plsql          => p_row.BLOQUE_PLSQL,
        p_roles_responsables    => p_row.ROLES_RESPONSABLES,
        p_usuarios_responsables => p_row.USUARIOS_RESPONSABLES );
    END IF;
  END create_or_update_row;

