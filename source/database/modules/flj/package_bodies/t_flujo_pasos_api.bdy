  FUNCTION create_or_update_row (
    p_id_paso               IN T_FLUJO_PASOS.ID_PASO%TYPE DEFAULT NULL /*PK*/,
    p_id_flujo              IN T_FLUJO_PASOS.ID_FLUJO%TYPE /*FK*/,
    p_nombre                IN T_FLUJO_PASOS.NOMBRE%TYPE,
    p_tipo                  IN T_FLUJO_PASOS.TIPO%TYPE,
    p_orden                 IN T_FLUJO_PASOS.ORDEN%TYPE,
    p_acciones_posibles     IN T_FLUJO_PASOS.ACCIONES_POSIBLES%TYPE,
    p_bloque_plsql          IN T_FLUJO_PASOS.BLOQUE_PLSQL%TYPE,
    p_roles_responsables    IN T_FLUJO_PASOS.ROLES_RESPONSABLES%TYPE,
    p_usuarios_responsables IN T_FLUJO_PASOS.USUARIOS_RESPONSABLES%TYPE )
  RETURN T_FLUJO_PASOS.ID_PASO%TYPE
  IS
  BEGIN
    IF row_exists(
      p_id_paso => p_id_paso
    )
    THEN
      RETURN update_row (
        p_id_paso               => p_id_paso /*PK*/,
        p_id_flujo              => p_id_flujo /*FK*/,
        p_nombre                => p_nombre,
        p_tipo                  => p_tipo,
        p_orden                 => p_orden,
        p_acciones_posibles     => p_acciones_posibles,
        p_bloque_plsql          => p_bloque_plsql,
        p_roles_responsables    => p_roles_responsables,
        p_usuarios_responsables => p_usuarios_responsables );
    ELSE
      RETURN create_row (
        p_id_paso               => p_id_paso /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_id_flujo              => p_id_flujo /*FK*/,
        p_nombre                => p_nombre,
        p_tipo                  => p_tipo,
        p_orden                 => p_orden,
        p_acciones_posibles     => p_acciones_posibles,
        p_bloque_plsql          => p_bloque_plsql,
