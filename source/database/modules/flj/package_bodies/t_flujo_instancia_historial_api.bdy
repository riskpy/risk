  PROCEDURE set_fecha (
    p_id_historial IN T_FLUJO_INSTANCIA_HISTORIAL.ID_HISTORIAL%TYPE /*PK*/,
    p_fecha        IN T_FLUJO_INSTANCIA_HISTORIAL.FECHA%TYPE )
