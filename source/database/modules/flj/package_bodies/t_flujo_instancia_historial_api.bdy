  PROCEDURE set_usuario (
    p_id_historial IN T_FLUJO_INSTANCIA_HISTORIAL.ID_HISTORIAL%TYPE /*PK*/,
    p_usuario      IN T_FLUJO_INSTANCIA_HISTORIAL.USUARIO%TYPE )
