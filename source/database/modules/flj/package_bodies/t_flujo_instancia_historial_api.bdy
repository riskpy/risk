  PROCEDURE set_id_instancia (
    p_id_historial IN T_FLUJO_INSTANCIA_HISTORIAL.ID_HISTORIAL%TYPE /*PK*/,
    p_id_instancia IN T_FLUJO_INSTANCIA_HISTORIAL.ID_INSTANCIA%TYPE )
  IS
  BEGIN
    UPDATE
      T_FLUJO_INSTANCIA_HISTORIAL
    SET
      ID_INSTANCIA         = p_id_instancia /*FK*/,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_HISTORIAL = p_id_historial;
  END set_id_instancia;

  PROCEDURE set_id_paso (
    p_id_historial IN T_FLUJO_INSTANCIA_HISTORIAL.ID_HISTORIAL%TYPE /*PK*/,
