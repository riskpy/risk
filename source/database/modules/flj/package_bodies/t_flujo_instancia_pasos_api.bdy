  PROCEDURE set_id_instancia (
    p_id_paso_instancia IN T_FLUJO_INSTANCIA_PASOS.ID_PASO_INSTANCIA%TYPE /*PK*/,
    p_id_instancia      IN T_FLUJO_INSTANCIA_PASOS.ID_INSTANCIA%TYPE )
  IS
  BEGIN
    UPDATE
      T_FLUJO_INSTANCIA_PASOS
    SET
      ID_INSTANCIA         = p_id_instancia /*FK*/,
      USUARIO_MODIFICACION = substr(coalesce(k_sistema.f_usuario, user), 1, 300),
      FECHA_MODIFICACION   = systimestamp
    WHERE
      ID_PASO_INSTANCIA = p_id_paso_instancia;
  END set_id_instancia;

  PROCEDURE set_id_paso (
    p_id_paso_instancia IN T_FLUJO_INSTANCIA_PASOS.ID_PASO_INSTANCIA%TYPE /*PK*/,
