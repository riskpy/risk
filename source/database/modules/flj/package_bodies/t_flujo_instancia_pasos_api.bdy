  END create_or_update_row;

  PROCEDURE create_or_update_row (
    p_id_paso_instancia     IN T_FLUJO_INSTANCIA_PASOS.ID_PASO_INSTANCIA%TYPE DEFAULT NULL /*PK*/,
    p_id_instancia          IN T_FLUJO_INSTANCIA_PASOS.ID_INSTANCIA%TYPE /*FK*/,
    p_id_paso               IN T_FLUJO_INSTANCIA_PASOS.ID_PASO%TYPE /*FK*/,
    p_estado                IN T_FLUJO_INSTANCIA_PASOS.ESTADO%TYPE,
    p_resultado             IN T_FLUJO_INSTANCIA_PASOS.RESULTADO%TYPE,
    p_fecha_inicio          IN T_FLUJO_INSTANCIA_PASOS.FECHA_INICIO%TYPE,
    p_fecha_fin             IN T_FLUJO_INSTANCIA_PASOS.FECHA_FIN%TYPE,
    p_roles_responsables    IN T_FLUJO_INSTANCIA_PASOS.ROLES_RESPONSABLES%TYPE,
    p_usuarios_responsables IN T_FLUJO_INSTANCIA_PASOS.USUARIOS_RESPONSABLES%TYPE )
  IS
  BEGIN
    IF row_exists(
      p_id_paso_instancia => p_id_paso_instancia
    )
    THEN
      update_row (
        p_id_paso_instancia     => p_id_paso_instancia /*PK*/,
        p_id_instancia          => p_id_instancia /*FK*/,
        p_id_paso               => p_id_paso /*FK*/,
        p_estado                => p_estado,
        p_resultado             => p_resultado,
        p_fecha_inicio          => p_fecha_inicio,
        p_fecha_fin             => p_fecha_fin,
        p_roles_responsables    => p_roles_responsables,
        p_usuarios_responsables => p_usuarios_responsables );
    ELSE
      create_row (
        p_id_paso_instancia     => p_id_paso_instancia /*PK*/ /*GENERATED BY DEFAULT ON NULL AS IDENTITY*/,
        p_id_instancia          => p_id_instancia /*FK*/,
        p_id_paso               => p_id_paso /*FK*/,
        p_estado                => p_estado,
        p_resultado             => p_resultado,
        p_fecha_inicio          => p_fecha_inicio,
        p_fecha_fin             => p_fecha_fin,
        p_roles_responsables    => p_roles_responsables,
        p_usuarios_responsables => p_usuarios_responsables );
    END IF;
  END create_or_update_row;

