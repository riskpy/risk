  END set_usuarios_responsables;

  FUNCTION get_default_row
  RETURN T_FLUJO_INSTANCIA_PASOS%ROWTYPE
  IS
    v_row T_FLUJO_INSTANCIA_PASOS%ROWTYPE;
  BEGIN
    v_row.ID_PASO_INSTANCIA := NULL /*PK*/;
    v_row.ESTADO            := 'EN_PROGRESO' ;
    v_row.FECHA_INICIO      := CURRENT_TIMESTAMP ;
    v_row.USUARIO_INSERCION := SUBSTR(USER, 1, 300) ;
    v_row.FECHA_INSERCION   := SYSTIMESTAMP ;
    RETURN v_row;
  END get_default_row;

END T_FLUJO_INSTANCIA_PASOS_API;
